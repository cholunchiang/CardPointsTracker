let cards = loadCards() || DEFAULTS;
if (!loadCards()) saveCards();

let currentTab  = 'all';
let currentNav  = 'cards';
let selEmoji    = '💳';
let selColor    = '#007AFF';
let searchQuery = '';
let currentCategoryFilter = '';
let currentPartnerFilter = '';  // For Miles view - filter by transfer partner
let currentSort = 'recent';  // 'recent' | 'points' | 'due' | 'name'
let editingCardId = null;  // Track if we're in edit mode
let searchTimeout;  // For debounced search (300ms delay)

// 🧭 Nav & Tabs
function switchNav(n) {
  currentNav = n;
  document.querySelectorAll('.nav-btn').forEach(b => b.classList.remove('active'));
  document.getElementById('nav-' + n).classList.add('active');
  renderAll();
}

function buildTabs() {
  const opts   = ['all','Me','Wife','Shared', ...new Set(cards.map(c => c.bank))];
  const labels = { all:'All Cards', Me:'👤 Mine', Wife:'👩 Wife', Shared:'🤝 Shared' };
  
  // Get count of expiring benefits for badge
  const expiringCount = getExpiringBenefits(7).length;
  
  document.getElementById('tabRow').innerHTML = opts.map(o => {
    let tabLabel = labels[o]||o;
    // Add badge to Coupons tab if there are expiring benefits
    if (o === 'all' && currentNav === 'coupons' && expiringCount > 0) {
      tabLabel = `🎁 Coupons <span style="background:#FF3B30;color:white;border-radius:10px;padding:2px 6px;font-size:10px;font-weight:700;margin-left:4px">${expiringCount}</span>`;
    }
    return `<button class="tab-pill ${o===currentTab?'active':''}" onclick="setTab('${o}')">${tabLabel}</button>`;
  }).join('');
}

function setTab(t) { currentTab = t; renderAll(); }

function handleSearch(v) {
  clearTimeout(searchTimeout);
  searchQuery = v.toLowerCase().trim();
  // Debounce: wait 300ms before rendering to avoid excessive re-renders
  searchTimeout = setTimeout(() => renderAll(), 300);
}

function filtered() {
  let list = cards;
  if (['Me','Wife','Shared'].includes(currentTab)) list = cards.filter(c => (c.owner||'Me') === currentTab);
  else if (currentTab !== 'all') list = cards.filter(c => c.bank === currentTab);
  if (searchQuery) list = list.filter(c =>
    c.name.toLowerCase().includes(searchQuery) ||
    c.bank.toLowerCase().includes(searchQuery) ||
    (c.owner||'Me').toLowerCase().includes(searchQuery) ||
    c.perks.some(p => p.toLowerCase().includes(searchQuery)) ||
    c.redeem.some(r => r.name.toLowerCase().includes(searchQuery)) ||
    (c.coupons||[]).some(x => x.text.toLowerCase().includes(searchQuery))
  );
  return list;
}

function filterByCategory(category) {
  currentCategoryFilter = category;
  renderAll();
}

function filterByPartner(partner) {
  currentPartnerFilter = partner;
  renderAll();
}

function setSortOrder(order) {
  currentSort = order;
  renderAll();
}

function sortCards(list) {
  const sorted = [...list];
  switch(currentSort) {
    case 'points':
      return sorted.sort((a, b) => b.points - a.points);
    case 'due':
      return sorted.sort((a, b) => {
        if (!a.due) return 1;
        if (!b.due) return -1;
        return new Date(a.due) - new Date(b.due);
      });
    case 'name':
      return sorted.sort((a, b) => a.name.localeCompare(b.name));
    case 'recent':
    default:
      return sorted.sort((a, b) => b.id - a.id);  // id is timestamp
  }
}

function getCardsFilteredByCategory(list) {
  if (!currentCategoryFilter) return list;
  
  // Filter cards that have the category (using normalized matching)
  const filtered = list.filter(c => {
    return (c.perks || []).some(p => {
      const cat = extractCategory(p);
      const normalized = normalizeCategory(cat);
      return normalized && normalized.toLowerCase() === currentCategoryFilter.toLowerCase();
    });
  });
  
  // Sort by earning rate for that category (highest first)
  filtered.sort((a, b) => {
    const rateA = getEarningRateForCategory(a, currentCategoryFilter);
    const rateB = getEarningRateForCategory(b, currentCategoryFilter);
    return rateB - rateA;
  });
  
  return filtered;
}

function getEarningRateForCategory(card, category) {
  for (const perk of (card.perks || [])) {
    const match = perk.match(/^(\d+(?:\.\d+)?)x\s+(.+)$/i);
    if (match) {
      const normalized = normalizeCategory(match[2]);
      if (normalized && normalized.toLowerCase() === category.toLowerCase()) {
        return parseFloat(match[1]);
      }
    }
  }
  return 0;
}

function populateCategoryFilter() {
  const categories = new Set();
  cards.forEach(c => {
    (c.perks || []).forEach(p => {
      const cat = extractCategory(p);
      if (cat) {
        const normalized = normalizeCategory(cat);
        if (normalized) categories.add(normalized);
      }
    });
  });
  
  const select = document.getElementById('categoryFilter');
  if (!select) return;
  select.innerHTML = '<option value="">All Categories</option>' +
    [...categories].sort().map(cat => 
      `<option value="${cat}">${cat}</option>`
    ).join('');
  
  // Restore selected value after rebuilding dropdown
  select.value = currentCategoryFilter;
}

// Hotel partner keywords for emoji detection
const HOTEL_PARTNERS = ['marriott', 'hilton', 'hyatt', 'ihg', 'wyndham', 'choice', 'accor', 'radisson', 'best western', 'hotel', 'hotels', 'i prefer'];

function getPartnerEmoji(partnerName) {
  const lower = partnerName.toLowerCase();
  if (HOTEL_PARTNERS.some(h => lower.includes(h))) {
    return '🏨';
  }
  return '✈️';
}

function populatePartnerFilter() {
  const partners = new Set();
  cards.forEach(c => {
    (c.redeem || []).forEach(r => {
      if (r.name) partners.add(r.name);
    });
  });
  
  const select = document.getElementById('categoryFilter');
  if (!select) return;
  select.innerHTML = '<option value="">All Partners</option>' +
    [...partners].sort().map(p => 
      `<option value="${p}">${getPartnerEmoji(p)} ${p}</option>`
    ).join('');
  
  // Restore selected value after rebuilding dropdown
  select.value = currentPartnerFilter;
}

function populateSortFilter() {
  const select = document.getElementById('sortFilter');
  if (!select) return;
  // Ensure the sort option matches current sort state
  select.value = currentSort;
}

// 🎨 Render
function renderAll() {
  buildTabs();
  
  // Use different filter based on current view
  if (currentNav === 'miles') {
    populatePartnerFilter();
    updateFilterDropdownHandler('partner');
  } else {
    populateCategoryFilter();
    updateFilterDropdownHandler('category');
  }
  
  populateSortFilter();
  const area = document.getElementById('contentArea');
  let list = filtered();
  
  // Apply appropriate filter based on view
  if (currentNav === 'miles') {
    list = getCardsFilteredByPartner(list);
  } else {
    list = getCardsFilteredByCategory(list);
  }
  
  list = sortCards(list);  // Apply sorting after filtering
  if (currentNav==='cards')   renderCards(area, list);
  else if (currentNav==='miles')   renderMiles(area, list);
  else if (currentNav==='coupons') renderCoupons(area, list);
  else renderSummary(area);
}

// Update filter dropdown handler based on view
function updateFilterDropdownHandler(type) {
  const select = document.getElementById('categoryFilter');
  if (!select) return;
  if (type === 'partner') {
    select.onchange = function() { filterByPartner(this.value); };
  } else {
    select.onchange = function() { filterByCategory(this.value); };
  }
}

// Filter cards by transfer partner
function getCardsFilteredByPartner(list) {
  if (!currentPartnerFilter) return list;
  return list.filter(c => {
    return (c.redeem || []).some(r => r.name === currentPartnerFilter);
  });
}

function tc(i) { return TC[i % TC.length]; }

function renderCards(area, list) {
  if (!list.length) { area.innerHTML = `<div class="empty-state"><span class="big-emoji">💳</span><strong>No cards yet</strong>Tap + to add your first card</div>`; return; }
  area.innerHTML = list.map(c => {
    const due      = c.due ? new Date(c.due).toLocaleDateString('en-US',{month:'short',day:'numeric'}) : '';
    const daysLeft = c.due ? Math.ceil((new Date(c.due)-new Date())/86400000) : 99;
    const prog     = Math.max(0, Math.min(100, (1-daysLeft/30)*100));
    const owner    = (c.owner||'Me').toLowerCase();
    // Only show earning rates on tiles (filter for "Nx" patterns)
    const earningRates = (c.perks || []).filter(p => /^\d+(\.\d+)?x\s/i.test(p)).sort((a, b) => { const rA = parseFloat(a.match(/^(\d+(?:\.\d+)?)/)[1]); const rB = parseFloat(b.match(/^(\d+(?:\.\d+)?)/)[1]); return rB - rA; }).slice(0, 4);
    return `<div class="card-tile" onclick="openDetail(${c.id})">
      <div class="card-tile-header">
        <div class="card-icon" style="background:${c.color}22">${cardIconHtml(c)}</div>
        <div class="card-title-block">
          <div class="card-name">${c.name}</div>
          <div class="card-bank"><span class="bank-chip">${c.bank}</span> <span class="owner-chip owner-${owner}">${c.owner||'Me'}</span></div>
        </div>
        <div class="points-badge"><div class="points-num">${c.points.toLocaleString()}</div><div class="points-unit">pts</div></div>
      </div>
      ${earningRates.length ? `<div class="tags-row">${earningRates.map(p=>`<span class="tag tag-${getCategoryColor(p)}">${p}</span>`).join('')}</div>` : ''}
      ${c.due ? `<div class="progress-section">
        <div class="progress-label"><span>Statement ${due}</span><span>${daysLeft>0?daysLeft+' days':'Today!'}</span></div>
        <div class="progress-bar-bg"><div class="progress-bar-fill" style="width:${prog}%"></div></div>
      </div>` : ''}
    </div>`;
  }).join('');
}

function renderMiles(area, list) {
  if (!list.length) { area.innerHTML = `<div class="empty-state"><span class="big-emoji">✈️</span><strong>No cards found</strong></div>`; return; }
  const pm = {};
  list.forEach(c => c.redeem.forEach(r => { if (!pm[r.name]) pm[r.name]=[]; pm[r.name].push({card:c,ratio:r.ratio,est:r.est}); }));
  let html = `<div class="section-label">Transfer Partners by Card</div>`;
  list.forEach(c => {
    html += `<div class="card-tile">
