/* BENEFIT CARDS - Period-based tracking */
.benefit-card {
  border-radius: var(--radius-md);
  padding: 12px;
  margin-bottom: 10px;
  background: rgba(255,149,0,0.06);
  border-left: 3px solid var(--color-warning);
  transition: all var(--transition-fast);
}

.benefit-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: 10px;
}

.benefit-text {
  font-size: 13px;
  font-weight: 600;
  color: var(--color-text-primary);
}

.benefit-meta {
  font-size: 11px;
  opacity: 0.6;
  margin-top: 3px;
}

.benefit-periods {
  display: flex;
  gap: 6px;
  flex-wrap: wrap;
}

.period-box {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  width: 42px;
  height: 32px;
  border-radius: var(--radius-sm);
  font-size: 12px;
  font-weight: 600;
  cursor: pointer;
  user-select: none;
  transition: all var(--transition-fast);
  border: 1px solid rgba(0,0,0,0.1);
  background: rgba(255,149,0,0.1);
  color: var(--color-warning);
}

.period-box:active {
  transform: scale(0.95);
}

.period-box.used {
  background: var(--color-success);
  color: #fff;
  border-color: var(--color-success);
}

@media (prefers-color-scheme: dark) {
  .period-box {
    background: rgba(255,159,10,0.15);
    border-color: rgba(255,159,10,0.3);
    color: #FF9F0A;
  }
  
  .period-box.used {
    background: #30D158;
    color: #000;
  }
}

/* Benefit Reminder Banner v3.5 */
.benefit-reminder-banner {
  background: linear-gradient(135deg, var(--color-warning), #ff9500);
  color: white;
  padding: var(--space-md);
  border-radius: var(--radius-lg);
  margin-bottom: var(--space-lg);
  box-shadow: 0 2px 8px rgba(255, 149, 0, 0.3);
}

.reminder-header {
  font-weight: 700;
  font-size: var(--font-size-lg);
  margin-bottom: var(--space-sm);
}

.reminder-list {
  font-size: var(--font-size-sm);
}

.reminder-item {
  padding: var(--space-xs) 0;
  opacity: 0.95;
}

.reminder-card {
  font-weight: 600;
}

.reminder-days {
  opacity: 0.9;
  font-style: italic;
  margin-left: 4px;
}

/* Period box expiring soon indicator */
.period-box.expiring {
  border: 2px solid var(--color-warning) !important;
  animation: pulse-warning 1.5s infinite;
}

@keyframes pulse-warning {
  0%, 100% {
    opacity: 1;
    box-shadow: 0 0 0 0 rgba(255, 149, 0, 0.4);
  }
  50% {
    opacity: 0.8;
    box-shadow: 0 0 0 4px rgba(255, 149, 0, 0.2);
  }
}

@media (prefers-color-scheme: dark) {
  .benefit-reminder-banner {
    background: linear-gradient(135deg, #FF9F0A, #ff7800);
    box-shadow: 0 2px 12px rgba(255, 159, 10, 0.35);
  }
}

