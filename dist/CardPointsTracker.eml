  'td bank':          { bg:'#34A853', fg:'#fff', abbr:'TD'    },
  'synchrony':        { bg:'#6E2B8B', fg:'#fff', abbr:'SYF'   },
};

function cardIconHtml(c) {
  const key   = (c.bank || '').toLowerCase();
  const brand = Object.entries(BANK_BRANDS).find(([k]) => key.includes(k))?.[1];
  if (brand) {
    return `<div style="width:36px;height:36px;border-radius:8px;background:${brand.bg};display:flex;align-items:center;justify-content:center;font-size:${brand.abbr.length>4?8:9}px;font-weight:800;color:${brand.fg};letter-spacing:0.2px;font-family:-apple-system,sans-serif">${brand.abbr}</div>`;
  }
  // For custom banks, create a generic badge with first 2-3 letters
  const abbr = c.bank.split(' ').map(w => w[0]).join('').toUpperCase().slice(0, 3);
  return `<div style="width:36px;height:36px;border-radius:8px;background:${c.color||'#8E8E93'};display:flex;align-items:center;justify-content:center;font-size:9px;font-weight:800;color:#fff;letter-spacing:0.2px;font-family:-apple-system,sans-serif">${abbr}</div>`;
}

// 💾 Persistence
function saveCards() { localStorage.setItem('cpCards', JSON.stringify(cards)); }

// 🔧 Hard reset corrupted data
(function(){
  try {
    const raw = localStorage.getItem('cpCards');
    if (!raw) return;
    const p = JSON.parse(raw);
    if (!Array.isArray(p) || p.length === 0) { localStorage.removeItem('cpCards'); return; }
    const bad = p.some(c =>
      !c || typeof c !== 'object' ||
      typeof c.name !== 'string' ||
      typeof c.bank !== 'string' ||
      !Array.isArray(c.redeem) ||
      !Array.isArray(c.perks) ||
      !Array.isArray(c.coupons) ||
      /[\u4e00-\u9fff]/.test(c.name + c.bank)
    );
    if (bad) localStorage.removeItem('cpCards');
  } catch(e) { localStorage.removeItem('cpCards'); }
})();

function loadCards() {
  try {
    const raw = localStorage.getItem('cpCards');
    if (!raw) return null;
    const parsed = JSON.parse(raw);
    if (!Array.isArray(parsed) || !parsed.length) return null;
    if (parsed.some(c => !c.name || !c.bank || !Array.isArray(c.redeem) || /[\u4e00-\u9fff]/.test(c.name + c.bank))) {
      localStorage.removeItem('cpCards');
      return null;
    }
    return parsed.map(c => {
      const card = {
        id:         c.id         ?? Date.now(),
        name:       c.name       ?? 'Unknown',
        bank:       c.bank       ?? 'Unknown',
        icon:       c.icon       ?? '💳',
        color:      c.color      ?? '#007AFF',
        points:     typeof c.points === 'number' ? c.points : 0,
        due:        c.due        ?? '',
        owner:      c.owner      ?? 'Me',
        annualFee:  typeof c.annualFee === 'number' ? c.annualFee : 0,
        openDate:   c.openDate   ?? null,
        perks:      Array.isArray(c.perks)   ? c.perks   : [],
        redeem:     Array.isArray(c.redeem)  ? c.redeem  : [],
        coupons:    Array.isArray(c.coupons) ? c.coupons : [],
        history:    Array.isArray(c.history) ? c.history : [],
        createdAt:  c.createdAt  ?? new Date(c.id).toISOString(),
        updatedAt:  c.updatedAt  ?? new Date().toISOString(),
      };
      
      // Normalize coupons to new benefit structure
      card.coupons = card.coupons.map(coupon => {
        // If it's the old format (has 'done' and 'expiry'), convert it
        if (coupon.hasOwnProperty('done')) {
          return {
            text: coupon.text || '',
            amount: coupon.amount || 0,
            yearlyTotal: coupon.yearlyTotal || 0,
            recurrence: coupon.recurrence || 'annual',
            periods: coupon.periods || {},
            expiry: coupon.expiry || null,
            lastReset: coupon.lastReset || new Date().toISOString(),
            nextReset: coupon.nextReset || null
          };
        }
        // Already new format
        return coupon;
      });
      
      // Initialize periods for all benefits if not present
      card.coupons = card.coupons.map(benefit => initializeBenefitPeriods(benefit));
      
      return card;
    });
  } catch(e) { localStorage.removeItem('cpCards'); return null; }
}

