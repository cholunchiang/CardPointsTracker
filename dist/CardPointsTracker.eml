// 🎁 Benefit/Perk Helper Functions v3.4+
/**
 * Get period labels based on recurrence type
 * monthly: [Jan, Feb, Mar, ...Dec]
 * quarterly: [Q1, Q2, Q3, Q4]
 * semi-annual: [H1, H2]
 * annual: [Year]
 */
function getPeriodLabels(recurrence) {
  switch(recurrence) {
    case 'monthly':
      return ['Jan', 'Feb', 'Mar', 'Apr', 'May', 'Jun', 'Jul', 'Aug', 'Sep', 'Oct', 'Nov', 'Dec'];
    case 'quarterly':
      return ['Q1', 'Q2', 'Q3', 'Q4'];
    case 'semi-annual':
      return ['H1', 'H2'];
    case 'annual':
    default:
      return ['Year'];
  }
}

/**
 * Get period key for a given recurrence and period index
 * Used to access periods object
 * @param {string} recurrence - Type of recurrence
 * @param {number} periodIdx - 0-based period index
 * @param {number} year - Optional year (default: current year)
 */
function getPeriodKey(recurrence, periodIdx, year = null) {
  if (!year) year = new Date().getFullYear();
  switch(recurrence) {
    case 'monthly':
      return `${year}-${String(periodIdx + 1).padStart(2, '0')}`;
    case 'quarterly':
      return `${year}-Q${periodIdx + 1}`;
    case 'semi-annual':
      return `${year}-H${periodIdx + 1}`;
    case 'annual':
    default:
      return `${year}`;
  }
}

/**
 * Get current period key based on recurrence
 */
function getCurrentPeriodKey(recurrence) {
  const now = new Date();
  const year = now.getFullYear();
  const month = now.getMonth();
  
  switch(recurrence) {
    case 'monthly':
      return `${year}-${String(month + 1).padStart(2, '0')}`;
    case 'quarterly':
      const quarter = Math.floor(month / 3) + 1;
      return `${year}-Q${quarter}`;
    case 'semi-annual':
      const half = month < 6 ? 1 : 2;
      return `${year}-H${half}`;
    case 'annual':
    default:
      return `${year}`;
  }
}

/**
 * Initialize benefit periods for current year
 * Creates empty period tracking structure
 */
function initializeBenefitPeriods(benefit) {
  // Check if periods exist AND have entries (not just empty object)
  if (benefit.periods && Object.keys(benefit.periods).length > 0) return benefit;
  
  const recurrence = benefit.recurrence || 'annual';
  const periodLabels = getPeriodLabels(recurrence);
  const periods = {};
  
  periodLabels.forEach((_, idx) => {
    const key = getPeriodKey(recurrence, idx);
    periods[key] = { used: false, amount: 0 };
  });
  
  benefit.periods = periods;
  return benefit;
}

/**
 * Get total used amount across all periods
 */
function getBenefitUsedTotal(benefit) {
  if (!benefit.periods) return 0;
  return Object.values(benefit.periods).reduce((sum, p) => sum + (p.used ? p.amount : 0), 0);
}

/**
 * Toggle benefit period usage
 */
function toggleBenefitPeriod(cardId, benefitIdx, periodKey) {
  const card = cards.find(c => c.id === cardId);
  if (!card || !card.coupons[benefitIdx]) return;
  
  const benefit = card.coupons[benefitIdx];
  if (!benefit.periods) benefit.periods = {};
  
  const periodData = benefit.periods[periodKey] = benefit.periods[periodKey] || { used: false, amount: 0 };
  periodData.used = !periodData.used;
  
  // Set amount if toggling on
  if (periodData.used && periodData.amount === 0) {
    periodData.amount = benefit.amount || benefit.yearlyTotal || 0;
  }
  
  saveCards();
  renderAll();
}

/**
 * Calculate next reset date based on recurrence (legacy, kept for compatibility)
 * recurrence: 'monthly' | 'quarterly' | 'semi-annual' | 'annual' | 'one-time'
 */
function getNextResetDate(benefit) {
  if (benefit.recurrence === 'one-time' || !benefit.lastReset) {
    return null;
  }
  
  const lastReset = new Date(benefit.lastReset);
  let next = new Date(lastReset);
  
  switch(benefit.recurrence) {
    case 'monthly':
      next.setMonth(next.getMonth() + 1);
      break;
    case 'quarterly':
      next.setMonth(next.getMonth() + 3);
      break;
    case 'semi-annual':
      next.setMonth(next.getMonth() + 6);
      break;
    case 'annual':
      next.setFullYear(next.getFullYear() + 1);
      break;
  }
  
  return next;
}

/**
 * Check if benefit should auto-reset based on recurrence
 */
function shouldResetBenefit(benefit) {
  if (benefit.recurrence === 'one-time') return false;
  if (!benefit.lastReset) return false;
  
  const nextReset = getNextResetDate(benefit);
  if (!nextReset) return false;
  
  const today = new Date();
  return today >= nextReset;
}

/**
 * Auto-reset benefits if needed
 */
function resetBenefitsIfNeeded(card) {
  if (!card.coupons || !Array.isArray(card.coupons)) return;
  
  const now = new Date().toISOString();
  card.coupons.forEach(benefit => {
    if (shouldResetBenefit(benefit)) {
      benefit.used = false;
      benefit.lastReset = now;
      benefit.nextReset = getNextResetDate(benefit)?.toISOString() || null;
    }
  });
}

/**
 * Get current period index for a recurrence type
 * monthly: 0-11
 * quarterly: 0-3
 * semi-annual: 0-1
 * annual: 0
 */
function getCurrentPeriodIndex(recurrence) {
  const now = new Date();
  switch(recurrence) {
    case 'monthly':
      return now.getMonth(); // 0-11
    case 'quarterly':
      return Math.floor(now.getMonth() / 3); // 0-3
    case 'semi-annual':
      return now.getMonth() < 6 ? 0 : 1; // 0-1
    case 'annual':
    default:
      return 0;
  }
}

/**
 * Get end date of current period
 */
function getCurrentPeriodEndDate(recurrence) {
  const now = new Date();
  const year = now.getFullYear();
  switch(recurrence) {
    case 'monthly':
      return new Date(year, now.getMonth() + 1, 0); // Last day of current month
    case 'quarterly':
      const q = Math.floor(now.getMonth() / 3);
      return new Date(year, (q + 1) * 3, 0); // Last day of quarter
    case 'semi-annual':
      return now.getMonth() < 6 ? new Date(year, 5, 30) : new Date(year, 11, 31);
    case 'annual':
    default:
      return new Date(year, 11, 31);
  }
}

/**
 * Get benefits expiring within N days
 * Returns array of {card, benefit, benefitIdx, daysUntil, periodKey, value}
 */
function getExpiringBenefits(daysThreshold = 7) {
  const expiring = [];
  const now = new Date();
  
  cards.forEach(card => {
    (card.coupons || []).forEach((benefit, idx) => {
      if (benefit.recurrence === 'one-time') return;
      
      const endDate = getCurrentPeriodEndDate(benefit.recurrence);
      const daysUntil = Math.ceil((endDate - now) / (1000 * 60 * 60 * 24));
      
      if (daysUntil <= daysThreshold && daysUntil >= 0) {
        // Check if current period is unused
        const periodIdx = getCurrentPeriodIndex(benefit.recurrence);
        const periodKey = getPeriodKey(benefit.recurrence, periodIdx);
        const periodData = (benefit.periods || {})[periodKey];
        
        if (!periodData || !periodData.used) {
          expiring.push({
            card,
            benefit,
            benefitIdx: idx,
            daysUntil,
            periodKey,
            value: benefit.amount || 0
          });
        }
      }
    });
  });
  
  return expiring.sort((a, b) => a.daysUntil - b.daysUntil);
}

/**
 * Initialize new period if needed (for year transitions)
 * Returns true if period was created
 */
function ensureCurrentPeriodExists(benefit) {
  const recurrence = benefit.recurrence || 'annual';
  const periodIdx = getCurrentPeriodIndex(recurrence);
  const periodKey = getPeriodKey(recurrence, periodIdx);
  
  if (!benefit.periods) benefit.periods = {};
  if (!benefit.periods[periodKey]) {
    benefit.periods[periodKey] = { used: false, amount: 0 };
    return true; // Period was created
  }
  return false;
}

/**
 * Auto-reset check on load
 * Ensures current period exists and initializes new periods
 */
function checkAndResetBenefits() {
  let changed = false;
  cards.forEach(card => {
    (card.coupons || []).forEach(benefit => {
      if (ensureCurrentPeriodExists(benefit)) {
        changed = true;
      }
    });
  });
  if (changed) saveCards();
}

