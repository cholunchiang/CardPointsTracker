// 📋 Detail Modal
function openDetail(id) {
  const c = cards.find(x=>x.id===id); if (!c) return;
  const due   = c.due ? new Date(c.due).toLocaleDateString('en-US',{year:'numeric',month:'long',day:'numeric'}) : 'Not set';
  const owner = (c.owner||'Me').toLowerCase();
  const age   = formatCardAge(c.openDate);
  const anniversary = getNextAnniversaryDate(c.openDate);
  const anniversaryStr = anniversary ? new Date(anniversary).toLocaleDateString('en-US',{year:'numeric',month:'long',day:'numeric'}) : 'N/A';
  // Separate earning rates from perks
