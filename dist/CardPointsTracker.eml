function renderCoupons(area, list) {
  // Check for auto-reset first and ensure current periods exist
  checkAndResetBenefits();
  
  // Get expiring benefits
  const expiring = getExpiringBenefits(7);
  
  let html = '';
  
  // Reminder banner
  if (expiring.length > 0) {
    html += `<div class="benefit-reminder-banner">
      <div class="reminder-header">⚠️ ${expiring.length} benefit${expiring.length > 1 ? 's' : ''} expiring soon!</div>
      <div class="reminder-list">
        ${expiring.map(e => `
          <div class="reminder-item">
            <span class="reminder-card">${e.card.name}</span>: 
            ${e.benefit.text} 
            <span class="reminder-days">(${e.daysUntil === 0 ? 'Today!' : e.daysUntil + ' days'})</span>
          </div>
        `).join('')}
      </div>
    </div>`;
  }
  
  let has = false;
  
  list.forEach(c => {
    if (!c.coupons||!c.coupons.length) return;
    has = true;
    
    html += `<div class="card-tile" style="cursor:default">
      <div class="card-tile-header" style="margin-bottom:12px">
        <div class="card-icon" style="background:${c.color}22">${cardIconHtml(c)}</div>
        <div class="card-title-block"><div class="card-name">${c.name}</div><div class="card-bank"><span class="bank-chip">${c.bank}</span></div></div>
      </div>`;
    
    // Render each benefit card with period boxes
    c.coupons.forEach((benefit, bidx) => {
      const recurrence = benefit.recurrence || 'annual';
      const periodLabels = getPeriodLabels(recurrence);
      const periods = benefit.periods || {};
      const amount = benefit.amount || 0;
      const yearlyTotal = benefit.yearlyTotal || amount;
      const usedTotal = getBenefitUsedTotal(benefit);
      
      // Check if this benefit is expiring
      const isExpiring = expiring.some(e => e.card.id === c.id && e.benefitIdx === bidx);
      
      const periodBoxesHtml = periodLabels.map((label, pidx) => {
        const periodKey = getPeriodKey(recurrence, pidx);
        const periodData = periods[periodKey] || { used: false, amount: 0 };
        const isUsed = periodData.used;
        // Add expiring class to current period if benefit is expiring
        const isCurrentPeriod = pidx === getCurrentPeriodIndex(recurrence);
        const expiringClass = isExpiring && isCurrentPeriod ? 'expiring' : '';
        return `<div class="period-box ${isUsed ? 'used' : ''} ${expiringClass}" onclick="toggleBenefitPeriod(${c.id},${bidx},'${periodKey}')" title="${label}: $${amount}">${label}</div>`;
      }).join('');
      
      html += `<div class="benefit-card">
        <div class="benefit-header">
          <div style="flex:1">
            <div class="benefit-text">${benefit.text}</div>
            <div class="benefit-meta">$${usedTotal}/$${yearlyTotal} · ${recurrence}</div>
          </div>
        </div>
        <div class="benefit-periods">
          ${periodBoxesHtml}
        </div>
      </div>`;
    });
    
    html += `</div>`;
  });
  
  if (!has) html = `${html}<div class="empty-state"><span class="big-emoji">🎁</span><strong>No perks yet</strong>Add benefits when creating a card</div>`;
  area.innerHTML = html;
}

