function autofillCard(val) {
  const key = val.toLowerCase().trim();
  const match = Object.keys(CARD_DB).find(k => key.includes(k)||k.includes(key));
  if (!match) return;
  const d = CARD_DB[match];
  document.getElementById('f-bank').value    = d.bank    || '';
  // v1.9: Use new renderPerkTags() instead of textarea
  renderPerkTags(d.perks || []);
  // v1.7: Handle new redeem format with per-partner ratios
  if (d.redeem && d.redeem.length) {
    renderRedeemRows(d.redeem);
  } else {
    document.getElementById('f-redeem-container').innerHTML = '';
  }
  // v3.4: Render benefits instead of raw coupons
  if (d.coupons && d.coupons.length) {
    const benefits = d.coupons.map(text => ({
      text,
      recurrence: 'annual',
      expiry: null,
      used: false,
      lastReset: new Date().toISOString(),
      nextReset: null
    }));
    renderBenefitRows(benefits);
  } else {
    document.getElementById('f-benefits-container').innerHTML = '';
  }
  if (d.icon)  selE(d.icon);
  if (d.color) selC(d.color);
}

