    if (customInput && customInput.style.display !== 'none') {
      bank = customInput.value.trim();
    }
  }
  
  if (!name || !bank) { alert('Please enter card name and bank'); return; }
  
  const pts   = parseInt(document.getElementById('f-points').value)||0;
  const openDate = document.getElementById('f-open-date').value;
  const due   = document.getElementById('f-due').value;
  const owner = document.getElementById('f-owner')?.value||'Me';
  const annualFee = parseInt(document.getElementById('f-annual-fee').value)||0;
  const perks = getPerks();  // v1.9: Use new getPerks() function
  const redeemData = getRedeemRows();
  const redeem = redeemData.map(r => {
    const parts = r.ratio.split(':').map(Number);
    const a = parts[0] || 1;
    const b = parts[1] || 1;
    return { name: r.name, ratio: r.ratio, est: Math.floor(pts / a * b) };
  });
  const coupons = getBenefits();  // v3.4: Use new getBenefits() function
  const now = new Date().toISOString();
  
  // Check if we're editing an existing card
  if (editingCardId) {
    // Update existing card
    const card = cards.find(c => c.id === editingCardId);
    if (card) {
      card.name = name;
      card.bank = bank;
      card.icon = selEmoji;
      card.color = selColor;
      card.points = pts;
      card.openDate = openDate || null;
      card.due = due;
      card.owner = owner;
      card.annualFee = annualFee;
      card.perks = perks.length ? perks : ['General spending'];
      card.redeem = redeem;
      card.coupons = coupons;  // v3.4: Use getBenefits() result
      card.updatedAt = now;  // Update timestamp when editing
      // Preserve history and createdAt
    }
    editingCardId = null;  // Reset edit mode
  } else {
    // Create new card
    cards.push({
      id: Date.now(),
      name,
      bank,
      icon: selEmoji,
      color: selColor,
      points: pts,
      openDate: openDate || null,
      due,
      owner,
      annualFee,
      perks: perks.length ? perks : ['General spending'],
      redeem: redeem,
      coupons: coupons,  // v3.4: Use getBenefits() result
      history: [],
      createdAt: now,
      updatedAt: now,
    });
  }
  
  saveCards();
  closeAddModal();
  renderAll();
}

// ☁️ iCloud Backup & Freshness Tracking
function getLastBackupDate() {
  return localStorage.getItem('cpLastBackup');
}

function getDaysSinceBackup() {
  const last = getLastBackupDate();
  if (!last) return null;
  const diff = Date.now() - new Date(last).getTime();
  return Math.floor(diff / (1000 * 60 * 60 * 24));
}

function shouldShowBackupReminder() {
  const days = getDaysSinceBackup();
  return days === null || days >= 30;
}

function formatLastBackup() {
  const last = getLastBackupDate();
  if (!last) return 'Never backed up';
  const days = getDaysSinceBackup();
  if (days === 0) return 'Today';
  if (days === 1) return 'Yesterday';
  return `${days} days ago`;
}

function exportBackup() {
  const now = new Date().toISOString();
  
  // Save last backup timestamp
  localStorage.setItem('cpLastBackup', now);
  
  // Calculate metadata for AI analysis
  const totalPoints = cards.reduce((sum, c) => sum + (c.points || 0), 0);
  const totalAnnualFees = cards.reduce((sum, c) => sum + (c.annualFee || 0), 0);
  const owners = [...new Set(cards.map(c => c.owner || 'Me'))];
  const banks = [...new Set(cards.map(c => c.bank))];
  
  // Calculate date range
  let oldestCard = null;
  let newestCard = null;
  if (cards.length > 0) {
    oldestCard = cards.reduce((min, c) => {
      const d = c.openDate || c.createdAt;
      if (!d) return min;
      return !min || d < min ? d : min;
    }, null);
    newestCard = cards.reduce((max, c) => {
      const d = c.openDate || c.createdAt;
      if (!d) return max;
      return !max || d > max ? d : max;
    }, null);
  }
  
  const metadata = {
    totalCards: cards.length,
    totalPoints: totalPoints,
    totalAnnualFees: totalAnnualFees,
    owners: owners,
    banks: banks,
    dateRange: {
      oldestCard: oldestCard,
      newestCard: newestCard
    }
  };
  
  const data = {
    version: 3,
    appVersion: '3.3',
    exported: now,
    lastBackup: now,
    metadata: metadata,
    cards: cards.map(c => ({
      ...c,
      createdAt: c.createdAt || new Date(c.id).toISOString(),
      updatedAt: c.updatedAt || now
    }))
  };
  
  const json     = JSON.stringify(data, null, 2);
  const blob     = new Blob([json], { type: 'application/json' });
  const url      = URL.createObjectURL(blob);
  const date     = new Date().toISOString().slice(0,10);
  const filename = `CardPoints_backup_${date}.json`;
  const a  = document.createElement('a');
  a.href   = url;
  a.download = filename;
  a.click();
  URL.revokeObjectURL(url);
}

function importBackup(event) {
  const file = event.target.files[0];
  if (!file) return;
  const reader = new FileReader();
  reader.onload = function(e) {
    try {
      const data   = JSON.parse(e.target.result);
      const version = data.version || 2;
      const parsed = data.cards || (Array.isArray(data) ? data : null);
      if (!parsed || !Array.isArray(parsed) || !parsed.length) {
        alert('Invalid backup file — no cards found.'); return;
      }
      if (!confirm(`Import ${parsed.length} cards? This will replace your current data.`)) return;
      
      const importTime = new Date().toISOString();
      
      cards = parsed.map(c => ({
        id:         c.id         ?? Date.now(),
        name:       c.name       ?? 'Unknown',
        bank:       c.bank       ?? 'Unknown',
        icon:       c.icon       ?? '💳',
        color:      c.color      ?? '#007AFF',
        points:     typeof c.points === 'number' ? c.points : 0,
        due:        c.due        ?? '',
        owner:      c.owner      ?? 'Me',
        annualFee:  typeof c.annualFee === 'number' ? c.annualFee : 0,
        openDate:   c.openDate   ?? null,
        perks:      Array.isArray(c.perks)   ? c.perks   : [],
        redeem:     Array.isArray(c.redeem)  ? c.redeem  : [],
        coupons:    Array.isArray(c.coupons) ? c.coupons : [],
        history:    Array.isArray(c.history) ? c.history : [],
        createdAt:  c.createdAt  ?? new Date(c.id).toISOString(),
        updatedAt:  c.updatedAt  ?? importTime
      }));
      
      // For v3+ backups, also preserve the lastBackup timestamp if present
      if (version >= 3 && data.lastBackup) {
        localStorage.setItem('cpLastBackup', data.lastBackup);
      }
      
      saveCards();
      renderAll();
      alert(`✅ Imported ${cards.length} cards successfully! (v${version})`);
    } catch(err) {
      alert('Could not read file — make sure it\'s a valid CardPoints backup JSON.');
    }
  };
  reader.readAsText(file);
  event.target.value = '';
}

// 📝 Log Points
let logCardId  = null;
let logType    = 'earned';

function openLogModal(id) {
  logCardId = id;
  logType   = 'earned';
  setLogType('earned');
  document.getElementById('log-amount').value = '';
  document.getElementById('log-note').value   = '';
  document.getElementById('log-date').value   = new Date().toISOString().slice(0,10);
  document.getElementById('logModal').classList.remove('hidden');
}
function closeLogModal() { document.getElementById('logModal').classList.add('hidden'); }

function setLogType(t) {
  logType = t;
  const eBtn = document.getElementById('log-type-earned');
  const sBtn = document.getElementById('log-type-spent');
  eBtn.style.borderColor  = t==='earned' ? '#34C759' : 'rgba(128,128,128,0.3)';
  eBtn.style.background   = t==='earned' ? 'rgba(52,199,89,0.12)' : 'transparent';
  eBtn.style.color        = t==='earned' ? '#34C759' : 'inherit';
  sBtn.style.borderColor  = t==='spent'  ? '#FF3B30' : 'rgba(128,128,128,0.3)';
  sBtn.style.background   = t==='spent'  ? 'rgba(255,59,48,0.08)' : 'transparent';
  sBtn.style.color        = t==='spent'  ? '#FF3B30' : 'inherit';
}

function saveLog() {
  const amt  = parseInt(document.getElementById('log-amount').value);
  const date = document.getElementById('log-date').value;
  const note = document.getElementById('log-note').value.trim();
  if (!amt || amt <= 0) { alert('Please enter a valid point amount'); return; }
  if (!date)            { alert('Please select a date'); return; }
  const c = cards.find(x => x.id === logCardId);
  if (!c) return;
  if (!c.history) c.history = [];
  c.history.unshift({ type: logType, amount: amt, date, note });
  c.points = logType === 'earned' ? c.points + amt : Math.max(0, c.points - amt);
  const ratio = c.redeem[0]?.ratio || '1:1';
  const [a, b] = ratio.split(':').map(Number);
  c.redeem = c.redeem.map(r => ({ ...r, est: Math.floor(c.points / (a||1) * (b||1)) }));
  saveCards();
  closeLogModal();
  openDetail(logCardId);
  renderAll();
}

// 🖱️ Background close
document.getElementById('detailModal').addEventListener('click',function(e){if(e.target===this)closeDetailModal();});
document.getElementById('addModal').addEventListener('click',function(e){if(e.target===this)closeAddModal();});
document.getElementById('logModal').addEventListener('click',function(e){if(e.target===this)closeLogModal();});

// 🚀 Init
renderAll();

</script>
