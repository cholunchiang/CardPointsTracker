 */
function openEditModal(id) {
  const card = cards.find(c => c.id === id);
  if (!card) return;
  
  closeDetailModal();  // Close detail modal first
  
  // Open the Add modal (this resets editingCardId to null)
  openAddModal();
  
  // Set edit mode flag AFTER openAddModal() since it resets the flag
  editingCardId = id;
  
  // Change title to "Edit Card"
  const titleElement = document.querySelector('#addModal .modal-title');
  if (titleElement) titleElement.textContent = '✏️ Edit Card';
  
  // Populate all fields with card data
  document.getElementById('f-name').value = card.name || '';
  document.getElementById('f-points').value = card.points || 0;
  document.getElementById('f-open-date').value = card.openDate || '';
  document.getElementById('f-due').value = card.due || '';
  document.getElementById('f-owner').value = card.owner || 'Me';
  document.getElementById('f-annual-fee').value = card.annualFee || 0;
  
  // Populate perks
  renderPerkTags(card.perks || []);
  document.getElementById('f-perks-input').value = '';
  
  // Populate transfer partners
  renderRedeemRows(card.redeem || []);
  
  // Populate benefits (v3.4)
  renderBenefitRows(card.coupons || []);
  
  // Set color and emoji
  selColor = card.color || '#007AFF';
  selEmoji = card.icon || '💳';
  
  // Handle bank selection
  const bankList = BANK_LIST.map(b => b.name);
  if (bankList.includes(card.bank)) {
    // Bank is in the predefined list
    selectBank(card.bank);
  } else {
    // Custom bank - select "Other" and populate custom input
    selectBank('Other');
    document.getElementById('f-bank-custom').value = card.bank;
    document.getElementById('f-bank').value = card.bank;
  }
}

