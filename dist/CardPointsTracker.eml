  if (!container) return;
  container.innerHTML = '';
  (perks || []).forEach((perk, idx) => {
    const colorClass = getCategoryColor(perk);
    const chip = document.createElement('div');
    chip.className = `perk-chip tag-${colorClass}`;
    chip.dataset.idx = idx;
    chip.dataset.perk = perk;  // Store perk text in data attribute
    chip.innerHTML = `${perk} <button type="button" class="perk-chip-remove" onclick="removePerk(${idx})">✕</button>`;
    container.appendChild(chip);
  });
}

function addPerk() {
  const input = document.getElementById('f-perks-input');
  const value = input.value.trim();
  if (!value) return;
  
  const currentPerks = getPerks();
  currentPerks.push(value);
  renderPerkTags(currentPerks);
  input.value = '';
  input.focus();
}

function removePerk(idx) {
  const currentPerks = getPerks();
  currentPerks.splice(idx, 1);
  renderPerkTags(currentPerks);
}

function getPerks() {
  const container = document.getElementById('f-perks-container');
  if (!container) return [];
  const chips = container.querySelectorAll('.perk-chip');
  const perks = [];
  chips.forEach(chip => {
    // Use data-perk attribute instead of textContent to avoid the × button
    const perk = chip.dataset.perk;
    if (perk) perks.push(perk);
  });
  return perks;
}

function handlePerkInput(event) {
  // Allow Enter key to add perk
  if (event.key === 'Enter') {
    event.preventDefault();
    addPerk();
  }
}

