  display: block;
  margin-bottom: 12px;
}

.empty-state strong {
  font-size: 18px;
  display: block;
  margin-bottom: 6px;
}

/* FAB (Floating Action Button) */
.fab {
  position: fixed;
  bottom: 90px;
  right: calc(50% - 215px + 16px);
  width: 52px;
  height: 52px;
  border-radius: 50%;
  border: none;
  cursor: pointer;
  font-size: 26px;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #fff;
  z-index: 200;
  transition: transform 0.2s;
}

.fab:active {
  transform: scale(0.92);
}

@media (prefers-color-scheme: light) {
  .fab {
    background: #007AFF;
    box-shadow: 0 4px 16px rgba(0,122,255,0.4);
  }
}

@media (prefers-color-scheme: dark) {
