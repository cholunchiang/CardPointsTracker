// 📅 Card Open Date & 5/24 Tracking
/**
 * Calculate card age from open date
 * Returns object { years, months } or null if no open date
 */
function getCardAge(openDate) {
  if (!openDate) return null;
  const opened = new Date(openDate);
  const today = new Date();
  const diffMs = today - opened;
  const diffDays = Math.floor(diffMs / 86400000);
  
  let years = 0, months = 0;
  let current = new Date(opened);
  
  while (current.getFullYear() < today.getFullYear() || 
         (current.getFullYear() === today.getFullYear() && current.getMonth() < today.getMonth())) {
    if (current.getMonth() === 11) {
      current = new Date(current.getFullYear() + 1, 0, 1);
      years++;
    } else {
      current = new Date(current.getFullYear(), current.getMonth() + 1, 1);
      months++;
    }
  }
  
  return { years, months, days: diffDays };
}

/**
 * Format card age as human-readable string (e.g., "2y 3m")
 */
function formatCardAge(openDate) {
  const age = getCardAge(openDate);
  if (!age) return 'Unknown';
  if (age.years > 0 && age.months > 0) return `${age.years}y ${age.months}m`;
  if (age.years > 0) return `${age.years}y`;
  if (age.months > 0) return `${age.months}m`;
  return `${age.days}d`;
}

/**
 * Get next anniversary date (1 year from open date)
 */
function getNextAnniversaryDate(openDate) {
  if (!openDate) return null;
  const opened = new Date(openDate);
  const next = new Date(opened.getFullYear() + 1, opened.getMonth(), opened.getDate());
  const today = new Date();
  if (next <= today) {
    next.setFullYear(next.getFullYear() + 1);
  }
  return next;
}

/**
 * Count cards opened in the last 24 months
 */
function getCardsOpenedInLast24Months(cardList, owner = null) {
  const today = new Date();
  const twoYearsAgo = new Date(today.getFullYear() - 2, today.getMonth(), today.getDate());
  
  return cardList.filter(c => {
    if (owner && (c.owner || 'Me') !== owner) return false;
    if (!c.openDate) return false;
    const opened = new Date(c.openDate);
    return opened >= twoYearsAgo && opened <= today;
  }).length;
}

/**
 * Get 5/24 status for a specific owner (Chase rule: max 5 new accounts in 24 months)
 */
function get524Status(cardList, owner) {
  const count = getCardsOpenedInLast24Months(cardList, owner);
  const status = count < 5 ? 'green' : count === 5 ? 'yellow' : 'red';
  const message = count < 5 ? `${count}/5` : count === 5 ? '5/5 (At Limit)' : `${count}/5 (Over)`;
  return { count, status, message };
}

/**
 * Get list of cards opened in last 24 months (for display)
 */
function getCardsOpenedInLast24MonthsList(cardList, owner = null) {
  const today = new Date();
  const twoYearsAgo = new Date(today.getFullYear() - 2, today.getMonth(), today.getDate());
  
  return cardList.filter(c => {
    if (owner && (c.owner || 'Me') !== owner) return false;
    if (!c.openDate) return false;
    const opened = new Date(c.openDate);
    return opened >= twoYearsAgo && opened <= today;
  }).sort((a, b) => new Date(b.openDate) - new Date(a.openDate));
}

// 💰 Annual Fees Helper Functions
function getTotalAnnualFees(cards, owner = null) {
  return cards.reduce((total, c) => {
    if (owner && (c.owner || 'Me') !== owner) return total;
    return total + (c.annualFee || 0);
  }, 0);
}

function getMyAnnualFees() {
  return getTotalAnnualFees(cards, 'Me');
}

function getWifeAnnualFees() {
  return getTotalAnnualFees(cards, 'Wife');
}

function getSharedAnnualFees() {
  return getTotalAnnualFees(cards, 'Shared');
}

// 📊 5/24 Tracker Status Section
function render524Section() {
  const myStatus = get524Status(cards, 'Me');
  const wifeStatus = get524Status(cards, 'Wife');
  const combinedCards = getCardsOpenedInLast24Months(cards);
  
  // Determine colors based on status
  const getStatusColor = (status) => {
    switch(status) {
      case 'green': return '#34C759';  // Safe
      case 'yellow': return '#FF9500'; // At limit
      case 'red': return '#FF3B30';    // Over limit
      default: return '#8E8E93';
    }
  };
  
  const getStatusIcon = (status) => {
    switch(status) {
      case 'green': return '✅';
      case 'yellow': return '⚠️';
      case 'red': return '🚫';
      default: return '📊';
    }
  };
  
  return `
    <div class="section-label" style="margin-top:20px">📊 5/24 Status (Chase Rule)</div>
    <div class="summary-card" style="background:rgba(100,200,255,0.06);border:1px solid rgba(100,200,255,0.15)">
      <div style="display:grid;grid-template-columns:1fr 1fr 1fr;gap:12px;text-align:center">
        <div>
          <div style="font-size:20px;font-weight:700;color:${getStatusColor(myStatus.status)}">${getStatusIcon(myStatus.status)} ${myStatus.count}/5</div>
          <div style="font-size:11px;color:#666;margin-top:2px">👤 Me</div>
        </div>
        <div>
          <div style="font-size:20px;font-weight:700;color:${getStatusColor(wifeStatus.status)}">${getStatusIcon(wifeStatus.status)} ${wifeStatus.count}/5</div>
          <div style="font-size:11px;color:#666;margin-top:2px">👩 Wife</div>
        </div>
        <div>
          <div style="font-size:20px;font-weight:700;color:${getStatusColor(combinedCards < 5 ? 'green' : combinedCards === 5 ? 'yellow' : 'red')}">${combinedCards}</div>
          <div style="font-size:11px;color:#666;margin-top:2px">Combined</div>
        </div>
      </div>
      <div style="font-size:12px;opacity:0.6;margin-top:10px;padding-top:10px;border-top:1px solid rgba(100,200,255,0.15);text-align:center">
        Cards opened in the last 24 months
      </div>
    </div>
  `;
}

