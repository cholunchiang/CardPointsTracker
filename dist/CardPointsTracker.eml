// ============================================================================
// CARD POINTS TRACKER - Main Application
// ============================================================================

// 🎨 Constants
const EMOJIS = ['💳','🏦','✈️','🎁','💰','🌟','🔷','💎','🎯','⭐','🏅','🎖️','💵','💴','💶','💷'];
const COLORS  = ['#FF6B6B','#FF9500','#FFCC02','#34C759','#00C7BE','#007AFF','#5856D6','#AF52DE','#FF2D55','#8E8E93'];
const TC      = ['','green','orange','purple','red','teal','','green','orange','purple'];

// 🏷️ Category Color Mapping
const CATEGORY_COLORS = {
  'dining': 'green',
  'restaurant': 'green',
  'restaurants': 'green',
  'travel': 'blue',
  'flights': 'blue',
  'hotels': 'purple',
  'flights booked directly': 'blue',
  'prepaid hotels': 'purple',
  'groceries': 'orange',
  'supermarkets': 'orange',
  'gas': 'red',
  'streaming': 'pink',
  'entertainment': 'pink',
  'drugstores': 'teal',
  'everything': 'gray',
  'prepaid': 'purple',
  'car rentals': 'blue',
  'cars': 'blue',
};

// Dynamic color assignment for unknown categories
let dynamicColorIndex = 0;
const DYNAMIC_COLORS = ['green', 'blue', 'orange', 'purple', 'red', 'pink', 'teal'];

function extractCategory(perk) {
  const match = perk.match(/^\d+(\.\d+)?x\s+(.+)$/i);
  return match ? match[2] : null;
}

// Normalize category names for grouping (e.g., "Dining worldwide" -> "Dining", "Everything else" -> "Everything")
const CATEGORY_ALIASES = {
  'dining worldwide': 'Dining',
  'restaurants worldwide': 'Dining',
  'restaurant': 'Dining',
  'restaurants': 'Dining',
  'everything else': 'Everything',
  'us supermarkets': 'Supermarkets',
  'supermarkets': 'Supermarkets',
  'groceries': 'Groceries',
  'flights booked directly': 'Flights',
  'flights': 'Flights',
  'travel': 'Travel',
  'hotels': 'Hotels',
  'prepaid hotels': 'Hotels',
  'gas': 'Gas',
  'transit': 'Transit',
  'streaming': 'Streaming',
  'entertainment': 'Entertainment',
  'drugstores': 'Drugstores',
};

function normalizeCategory(cat) {
  if (!cat) return null;
  const lower = cat.toLowerCase();
  // Check for alias match
  for (const [alias, normalized] of Object.entries(CATEGORY_ALIASES)) {
    if (lower.includes(alias) || alias.includes(lower)) return normalized;
  }
  // Check if it starts with a known category
  for (const [alias, normalized] of Object.entries(CATEGORY_ALIASES)) {
    if (lower.startsWith(alias.split(' ')[0])) return normalized;
  }
  // Return original with title case
  return cat.charAt(0).toUpperCase() + cat.slice(1);
}

function getCategoryColor(perk) {
  const category = extractCategory(perk);
  if (!category) return 'blue';
  
  const categoryLower = category.toLowerCase();
  
  // Check known categories (partial match)
  for (const [key, color] of Object.entries(CATEGORY_COLORS)) {
    if (categoryLower.includes(key)) return color;
  }
  
  // Assign dynamic color for unknown categories
  const assignedColor = DYNAMIC_COLORS[dynamicColorIndex % DYNAMIC_COLORS.length];
  CATEGORY_COLORS[categoryLower] = assignedColor;
  dynamicColorIndex++;
  return assignedColor;
}

// 🏦 Bank Logo Map
const BANK_BRANDS = {
  'chase':            { bg:'#117ACA', fg:'#fff', abbr:'CHASE' },
  'american express': { bg:'#016FD0', fg:'#fff', abbr:'AMEX'  },
