<!DOCTYPE html>=0A<html lang=3D"zh-TW">=0A<head>=0A<meta charset=3D"UTF-8">=0A<meta name=3D"viewport" content=3D"width=3Ddevice-width, initial-scale=3D1.0, maximum-scale=3D1.0">=0A<title>=00 Card Points Tracker</title>=0A<style>=0A  :root { color-scheme: light dark; }=0A=0A  * { box-sizing: border-box; margin: 0; padding: 0; }=0A=0A  body {=0A    font-family: -apple-system, BlinkMacSystemFont, 'SF Pro Display', 'SF Pro Text', sans-serif;=0A    min-height: 100%;=0A    padding: 0;=0A    transition: background 0.3s, color 0.3s;=0A    -webkit-font-smoothing: antialiased;=0A  }=0A=0A  @media (prefers-color-scheme: light) {=0A    body { background: #f2f2f7; color: #1d1d1f; }=0A    .top-bar { background: rgba(255,255,255,0.85); border-bottom: 1px solid rgba(0,0,0,0.1); }=0A    .search-box { background: rgba(118,118,128,0.12); color: #1d1d1f; }=0A    .search-box::placeholder { color: #86868b; }=0A    .card-tile { background: #fff; border: 1px solid rgba(0,0,0,0.08); }=0A    .card-tile:hover { box-shadow: 0 6px 24px rgba(0,0,0,0.12); }=0A    .section-label { color: #86868b; }=0A    .tag { background: rgba(0,122,255,0.1); color: #007AFF; }=0A    .tag.green { background: rgba(52,199,89,0.12); color: #34C759; }=0A    .tag.orange { background: rgba(255,149,0,0.12); color: #FF9500; }=0A    .tag.purple { background: rgba(175,82,222,0.12); color: #AF52DE; }=0A    .tag.red { background: rgba(255,59,48,0.12); color: #FF3B30; }=0A    .tag.teal { background: rgba(90,200,250,0.18); color: #32ADE6; }=0A    .modal-bg { background: rgba(0,0,0,0.35); }=0A    .modal { background: #fff; }=0A    .modal-header { border-bottom: 1px solid rgba(0,0,0,0.08); }=0A    .detail-row { border-bottom: 1px solid rgba(0,0,0,0.06); }=0A    .detail-icon-bg { background: rgba(0,122,255,0.1); }=0A    .empty-state { color: #86868b; }=0A    .add-btn { background: #007AFF; }=0A    .add-btn:hover { background: #0071e3; }=0A    .form-input { background: rgba(118,118,128,0.1); border: 1px solid rgba(0,0,0,0.1); color: #1d1d1f; }=0A    .form-input:focus { border-color: #007AFF; background: #fff; }=0A    .cancel-btn { background: rgba(118,118,128,0.15); color: #1d1d1f; }=0A    .bank-chip { background: rgba(0,0,0,0.06); color: #3c3c43; }=0A    .coupon-item { background: rgba(255,149,0,0.08); border-left: 3px solid #FF9500; }=0A    .coupon-item.used { opacity: 0.45; }=0A    .nav-bar { background: rgba(255,255,255,0.9); border-top: 1px solid rgba(0,0,0,0.1); }=0A    .nav-btn.active { color: #007AFF; }=0A    .nav-btn { color: #86868b; }=0A    .fab { background: #007AFF; box-shadow: 0 4px 16px rgba(0,122,255,0.4); }=0A    .summary-card { background: linear-gradient(135deg, #007AFF, #5AC8FA); color: #fff; }=0A    .progress-bar-bg { background: rgba(0,0,0,0.08); }=0A    .redemption-item { background: rgba(0,0,0,0.03); border: 1px solid rgba(0,0,0,0.06); }=0A  }=0A=0A  @media (prefers-color-scheme: dark) {=0A    body { background: #1c1c1e; color: #f5f5f7; }=0A    .top-bar { background: rgba(28,28,30,0.92); border-bottom: 1px solid rgba(255,255,255,0.08); }=0A    .search-box { background: rgba(118,118,128,0.24); color: #f5f5f7; }=0A    .search-box::placeholder { color: #636366; }=0A    .card-tile { background: #2c2c2e; border: 1px solid rgba(255,255,255,0.08); }=0A    .card-tile:hover { box-shadow: 0 6px 24px rgba(0,0,0,0.4); }=0A    .section-label { color: #636366; }=0A    .tag { background: rgba(10,132,255,0.2); color: #0A84FF; }=0A    .tag.green { background: rgba(48,209,88,0.18); color: #30D158; }=0A    .tag.orange { background: rgba(255,159,10,0.18); color: #FF9F0A; }=0A    .tag.purple { background: rgba(191,90,242,0.18); color: #BF5AF2; }=0A    .tag.red { background: rgba(255,69,58,0.18); color: #FF453A; }=0A    .tag.teal { background: rgba(100,210,255,0.18); color: #64D2FF; }=0A    .modal-bg { background: rgba(0,0,0,0.6); }=0A    .modal { background: #2c2c2e; }=0A    .modal-header { border-bottom: 1px solid rgba(255,255,255,0.08); }=0A    .detail-row { border-bottom: 1px solid rgba(255,255,255,0.06); }=0A    .detail-icon-bg { background: rgba(10,132,255,0.2); }=0A    .empty-state { color: #636366; }=0A    .add-btn { background: #0A84FF; }=0A    .add-btn:hover { background: #007AFF; }=0A    .form-input { background: rgba(118,118,128,0.2); border: 1px solid rgba(255,255,255,0.1); color: #f5f5f7; }=0A    .form-input:focus { border-color: #0A84FF; background: rgba(10,132,255,0.08); }=0A    .cancel-btn { background: rgba(118,118,128,0.25); color: #f5f5f7; }=0A    .bank-chip { background: rgba(255,255,255,0.1); color: #ebebf5; }=0A    .coupon-item { background: rgba(255,159,10,0.1); border-left: 3px solid #FF9F0A; }=0A    .coupon-item.used { opacity: 0.35; }=0A    .nav-bar { background: rgba(28,28,30,0.95); border-top: 1px solid rgba(255,255,255,0.08); }=0A    .nav-btn.active { color: #0A84FF; }=0A    .nav-btn { color: #636366; }=0A    .fab { background: #0A84FF; box-shadow: 0 4px 20px rgba(10,132,255,0.45); }=0A    .summary-card { background: linear-gradient(135deg, #0A84FF, #30D158); color: #fff; }=0A    .progress-bar-bg { background: rgba(255,255,255,0.1); }=0A    .redemption-item { background: rgba(255,255,255,0.04); border: 1px solid rgba(255,255,255,0.08); }=0A  }=0A=0A  /* =00=00 Layout =00=00 */=0A  #app { max-width: 430px; margin: 0 auto; position: relative; }=0A=0A  .top-bar {=0A    position: sticky; top: 0; z-index: 100;=0A    padding: 16px 16px 12px;=0A    backdrop-filter: blur(20px); -webkit-backdrop-filter: blur(20px);=0A  }=0A  .top-bar h1 { font-size: 28px; font-weight: 700; letter-spacing: -0.5px; margin-bottom: 10px; }=0A  .top-bar h1 span { font-size: 26px; }=0A=0A  .search-wrap { position: relative; }=0A  .search-icon { position: absolute; left: 10px; top: 50%; transform: translateY(-50%); font-size: 15px; pointer-events: none; opacity: 0.5; }=0A  .search-box {=0A    width: 100%; padding: 8px 12px 8px 34px;=0A    border: none; border-radius: 12px;=0A    font-size: 15px; outline: none;=0A    transition: all 0.2s;=0A  }=0A=0A  .tab-row {=0A    display: flex; gap: 6px; padding: 10px 16px 0;=0A    overflow-x: auto; -webkit-overflow-scrolling: touch;=0A    scrollbar-width: none;=0A  }=0A  .tab-row::-webkit-scrollbar { display: none; }=0A  .tab-pill {=0A    flex-shrink: 0; padding: 5px 14px;=0A    border-radius: 20px; border: none; cursor: pointer;=0A    font-size: 13px; font-weight: 500;=0A    transition: all 0.2s;=0A  }=0A  @media (prefers-color-scheme: light) {=0A    .tab-pill { background: rgba(118,118,128,0.12); color: #3c3c43; }=0A    .tab-pill.active { background: #007AFF; color: #fff; }=0A  }=0A  @media (prefers-color-scheme: dark) {=0A    .tab-pill { background: rgba(118,118,128,0.25); color: #ebebf5; }=0A    .tab-pill.active { background: #0A84FF; color: #fff; }=0A  }=0A=0A  .content-area { padding: 12px 16px 100px; }=0A=0A  .section-label {=0A    font-size: 12px; font-weight: 600; letter-spacing: 0.5px;=0A    text-transform: uppercase; margin: 14px 0 8px;=0A  }=0A=0A  /* =00=00 Card Tile =00=00 */=0A  .card-tile {=0A    border-radius: 16px; padding: 16px;=0A    margin-bottom: 10px; cursor: pointer;=0A    transition: transform 0.15s, box-shadow 0.2s;=0A    backdrop-filter: blur(12px); -webkit-backdrop-filter: blur(12px);=0A  }=0A  .card-tile:active { transform: scale(0.98); }=0A=0A  .card-tile-header {=0A    display: flex; align-items: center; gap: 12px; margin-bottom: 12px;=0A  }=0A  .card-icon {=0A    width: 44px; height: 44px; border-radius: 12px;=0A    display: flex; align-items: center; justify-content: center;=0A    font-size: 22px; flex-shrink: 0;=0A  }=0A  .card-title-block { flex: 1; min-width: 0; }=0A  .card-name { font-size: 16px; font-weight: 600; }=0A  .card-bank { font-size: 12px; margin-top: 2px; }=0A  .bank-chip {=0A    display: inline-block; padding: 2px 8px;=0A    border-radius: 6px; font-size: 11px; font-weight: 500;=0A  }=0A  .points-badge {=0A    text-align: right; flex-shrink: 0;=0A  }=0A  .points-num { font-size: 20px; font-weight: 700; }=0A  .points-unit { font-size: 11px; opacity: 0.6; }=0A=0A  .tags-row { display: flex; flex-wrap: wrap; gap: 5px; margin-bottom: 10px; }=0A  .tag {=0A    padding: 3px 10px; border-radius: 8px;=0A    font-size: 12px; font-weight: 500;=0A  }=0A=0A  .progress-section { margin-top: 4px; }=0A  .progress-label {=0A    display: flex; justify-content: space-between;=0A    font-size: 11px; opacity: 0.65; margin-bottom: 4px;=0A  }=0A  .progress-bar-bg { border-radius: 4px; height: 5px; overflow: hidden; }=0A  .progress-bar-fill {=0A    height: 100%; border-radius: 4px;=0A    background: linear-gradient(90deg, #007AFF, #5AC8FA);=0A    transition: width 0.6s ease;=0A  }=0A=0A  /* =00=00 Summary Card =00=00 */=0A  .summary-card {=0A    border-radius: 20px; padding: 20px; margin-bottom: 16px;=0A    position: relative; overflow: hidden;=0A  }=0A  .summary-card::before {=0A    content: ''; position: absolute;=0A    top: -20px; right: -20px; width: 100px; height: 100px;=0A    background: rgba(255,255,255,0.1); border-radius: 50%;=0A  }=0A  .summary-title { font-size: 13px; font-weight: 500; opacity: 0.85; }=0A  .summary-num { font-size: 36px; font-weight: 800; letter-spacing: -1px; margin: 4px 0; }=0A  .summary-sub { font-size: 12px; opacity: 0.75; }=0A=0A  /* =00=00 FAB =00=00 */=0A  .fab {=0A    position: fixed; bottom: 90px; right: calc(50% - 215px + 16px);=0A    width: 52px; height: 52px; border-radius: 50%;=0A    border: none; cursor: pointer; font-size: 26px;=0A    display: flex; align-items: center; justify-content: center;=0A    color: #fff; z-index: 200;=0A    transition: transform 0.2s;=0A  }=0A  .fab:active { transform: scale(0.92); }=0A=0A  /* =00=00 Nav Bar =00=00 */=0A  .nav-bar {=0A    position: fixed; bottom: 0; left: 50%; transform: translateX(-50%);=0A    width: 100%; max-width: 430px;=0A    display: flex; padding: 8px 0 20px;=0A    backdrop-filter: blur(20px); -webkit-backdrop-filter: blur(20px);=0A    z-index: 150;=0A  }=0A  .nav-btn {=0A    flex: 1; display: flex; flex-direction: column;=0A    align-items: center; gap: 2px;=0A    background: none; border: none; cursor: pointer;=0A    font-size: 11px; font-weight: 500;=0A    transition: color 0.2s;=0A  }=0A  .nav-btn .nav-icon { font-size: 22px; }=0A=0A  /* =00=00 Modal =00=00 */=0A  .modal-bg {=0A    position: fixed; inset: 0; z-index: 300;=0A    display: flex; align-items: flex-end;=0A    backdrop-filter: blur(4px); -webkit-backdrop-filter: blur(4px);=0A  }=0A  .modal-bg.hidden { display: none; }=0A  .modal {=0A    width: 100%; max-width: 430px; margin: 0 auto;=0A    border-radius: 24px 24px 0 0;=0A    max-height: 88vh; overflow-y: auto;=0A    animation: slideUp 0.3s cubic-bezier(0.34,1.56,0.64,1);=0A  }=0A  @keyframes slideUp {=0A    from { transform: translateY(100%); }=0A    to { transform: translateY(0); }=0A  }=0A  .modal-handle {=0A    width: 36px; height: 4px; border-radius: 2px;=0A    background: rgba(128,128,128,0.3); margin: 10px auto 4px;=0A  }=0A  .modal-header {=0A    display: flex; align-items: center; justify-content: space-between;=0A    padding: 12px 20px 14px;=0A  }=0A  .modal-title { font-size: 20px; font-weight: 700; }=0A  .close-btn {=0A    width: 30px; height: 30px; border-radius: 50%; border: none;=0A    cursor: pointer; font-size: 16px; display: flex;=0A    align-items: center; justify-content: center;=0A    background: rgba(128,128,128,0.2); color: inherit;=0A  }=0A  .modal-body { padding: 0 20px 24px; }=0A=0A  .detail-row {=0A    display: flex; align-items: flex-start; gap: 12px;=0A    padding: 14px 0;=0A  }=0A  .detail-icon-bg {=0A    width: 36px; height: 36px; border-radius: 10px;=0A    display: flex; align-items: center; justify-content: center;=0A    font-size: 18px; flex-shrink: 0;=0A  }=0A  .detail-content { flex: 1; }=0A  .detail-label { font-size: 12px; opacity: 0.6; margin-bottom: 3px; }=0A  .detail-value { font-size: 14px; font-weight: 500; }=0A=0A  .coupon-item {=0A    padding: 10px 12px; border-radius: 10px; margin-bottom: 6px;=0A    display: flex; align-items: center; gap: 10px;=0A    transition: opacity 0.2s;=0A  }=0A  .coupon-check {=0A    width: 20px; height: 20px; border-radius: 50%; border: none;=0A    cursor: pointer; font-size: 13px; display: flex;=0A    align-items: center; justify-content: center;=0A    flex-shrink: 0; transition: all 0.2s;=0A  }=0A  @media (prefers-color-scheme: light) {=0A    .coupon-check { background: rgba(255,149,0,0.2); color: #FF9500; }=0A    .coupon-check.done { background: #34C759; color: #fff; }=0A  }=0A  @media (prefers-color-scheme: dark) {=0A    .coupon-check { background: rgba(255,159,10,0.2); color: #FF9F0A; }=0A    .coupon-check.done { background: #30D158; color: #fff; }=0A  }=0A  .coupon-text { flex: 1; font-size: 13px; font-weight: 500; }=0A  .coupon-expiry { font-size: 11px; opacity: 0.55; }=0A=0A  .redemption-item {=0A    border-radius: 12px; padding: 12px; margin-bottom: 8px;=0A    display: flex; justify-content: space-between; align-items: center;=0A  }=0A  .redemption-name { font-size: 14px; font-weight: 600; }=0A  .redemption-ratio { font-size: 13px; opacity: 0.7; }=0A  .redemption-value { font-size: 15px; font-weight: 700; }=0A=0A  /* =00=00 Add Card Form =00=00 */=0A  .form-group { margin-bottom: 14px; }=0A  .form-label { font-size: 13px; font-weight: 600; margin-bottom: 6px; opacity: 0.8; display: block; }=0A  .form-input {=0A    width: 100%; padding: 10px 14px;=0A    border-radius: 12px; font-size: 14px;=0A    outline: none; transition: all 0.2s;=0A  }=0A  .form-row { display: grid; grid-template-columns: 1fr 1fr; gap: 10px; }=0A  .form-actions { display: flex; gap: 10px; margin-top: 20px; }=0A  .add-btn, .cancel-btn {=0A    flex: 1; padding: 13px; border-radius: 14px; border: none;=0A    font-size: 15px; font-weight: 600; cursor: pointer;=0A    transition: all 0.2s;=0A  }=0A  .add-btn { color: #fff; }=0A=0A  .emoji-grid {=0A    display: grid; grid-template-columns: repeat(6, 1fr); gap: 6px; margin-top: 6px;=0A  }=0A  .emoji-btn {=0A    aspect-ratio: 1; border-radius: 10px; border: none;=0A    font-size: 20px; cursor: pointer; display: flex;=0A    align-items: center; justify-content: center;=0A    transition: all 0.15s;=0A  }=0A  @media (prefers-color-scheme: light) {=0A    .emoji-btn { background: rgba(118,118,128,0.1); }=0A    .emoji-btn.selected { background: rgba(0,122,255,0.2); outline: 2px solid #007AFF; }=0A  }=0A  @media (prefers-color-scheme: dark) {=0A    .emoji-btn { background: rgba(118,118,128,0.2); }=0A    .emoji-btn.selected { background: rgba(10,132,255,0.25); outline: 2px solid #0A84FF; }=0A  }=0A=0A  .color-grid { display: flex; gap: 8px; flex-wrap: wrap; margin-top: 6px; }=0A  .color-btn {=0A    width: 32px; height: 32px; border-radius: 50%; border: 3px solid transparent;=0A    cursor: pointer; transition: all 0.15s;=0A  }=0A  .color-btn.selected { border-color: #fff; transform: scale(1.15); box-shadow: 0 0 0 2px #007AFF; }=0A=0A  .empty-state {=0A    text-align: center; padding: 60px 20px;=0A    font-size: 15px; line-height: 1.6;=0A  }=0A  .empty-state .big-emoji { font-size: 56px; display: block; margin-bottom: 12px; }=0A  .empty-state strong { font-size: 18px; display: block; margin-bottom: 6px; }=0A=0A  .owner-chip { display:inline-block; padding:1px 7px; border-radius:6px; font-size:11px; font-weight:600; margin-left:3px; }=0A  .owner-me   { background:rgba(0,122,255,0.13); color:#007AFF; }=0A  .owner-wife { background:rgba(255,45,85,0.13);  color:#FF2D55; }=0A  .owner-shared { background:rgba(52,199,89,0.13); color:#34C759; }=0A=0A  @media (prefers-color-scheme: dark) {=0A    .owner-me   { background:rgba(10,132,255,0.2); color:#0A84FF; }=0A    .owner-wife { background:rgba(255,69,58,0.2);  color:#FF453A; }=0A    .owner-shared { background:rgba(48,209,88,0.2); color:#30D158; }=0A  }=0A=0A  .view { display: none; }=0A  .view.active { display: block; }=0A</style>=0A</head>=0A<body>=0A<div id=3D"app">=0A  <!-- Top Bar -->=0A  <div class=3D"top-bar">=0A    <h1><span>=00</span> Card Points</h1>=0A    <div class=3D"search-wrap">=0A      <span class=3D"search-icon">=00</span>=0A      <input class=3D"search-box" id=3D"searchBox" type=3D"text" placeholder=3D"Search cards, airlines, rewards=00" oninput=3D"handleSearch(this.value)">=0A    </div>=0A  </div>=0A=0A  <!-- Tabs -->=0A  <div class=3D"tab-row" id=3D"tabRow"></div>=0A=0A  <!-- Content -->=0A  <div class=3D"content-area" id=3D"contentArea"></div>=0A=0A  <!-- FAB -->=0A  <button class=3D"fab" onclick=3D"openAddModal()" title=3D"=00=00=00=00=00">=00</button>=0A=0A  <!-- Nav Bar -->=0A  <div class=3D"nav-bar">=0A    <button class=3D"nav-btn active" id=3D"nav-cards" onclick=3D"switchNav('cards')">=0A      <span class=3D"nav-icon">=00</span>Cards=0A    </button>=0A    <button class=3D"nav-btn" id=3D"nav-miles" onclick=3D"switchNav('miles')">=0A      <span class=3D"nav-icon">=00</span>Miles=0A    </button>=0A    <button class=3D"nav-btn" id=3D"nav-coupons" onclick=3D"switchNav('coupons')">=0A      <span class=3D"nav-icon">=00</span>Perks=0A    </button>=0A    <button class=3D"nav-btn" id=3D"nav-summary" onclick=3D"switchNav('summary')">=0A      <span class=3D"nav-icon">=00</span>Summary=0A    </button>=0A  </div>=0A</div>=0A=0A<!-- Card Detail Modal -->=0A<div class=3D"modal-bg hidden" id=3D"detailModal">=0A  <div class=3D"modal" id=3D"detailModalContent"></div>=0A</div>=0A=0A<!-- Add Card Modal -->=0A<div class=3D"modal-bg hidden" id=3D"addModal">=0A  <div class=3D"modal" id=3D"addModalContent">=0A    <div class=3D"modal-handle"></div>=0A    <div class=3D"modal-header">=0A      <span class=3D"modal-title">Add Credit Card</span>=0A      <button class=3D"close-btn" onclick=3D"closeAddModal()">&times;</button>=0A    </div>=0A    <div class=3D"modal-body">=0A      <div class=3D"form-group">=0A        <label class=3D"form-label">Card Name</label>=0A        <input class=3D"form-input" id=3D"f-name" placeholder=3D"e.g. Chase Sapphire Preferred" oninput=3D"autofillCard(this.value)" />=0A      </div>=0A      <div class=3D"form-row">=0A        <div class=3D"form-group">=0A          <label class=3D"form-label">Bank</label>=0A          <input class=3D"form-input" id=3D"f-bank" placeholder=3D"e.g. Chase" />=0A        </div>=0A        <div class=3D"form-group">=0A          <label class=3D"form-label">Current Points</label>=0A          <input class=3D"form-input" id=3D"f-points" type=3D"number" placeholder=3D"0" />=0A        </div>=0A      </div>=0A      <div class=3D"form-group">=0A        <label class=3D"form-label">Statement Date</label>=0A        <input class=3D"form-input" id=3D"f-due" type=3D"date" />=0A      </div>=0A      <div class=3D"form-group">=0A        <label class=3D"form-label">Reward Categories <span style=3D"opacity:0.5;font-weight:400">(auto-filled)</span></label>=0A        <input class=3D"form-input" id=3D"f-perks" placeholder=3D"e.g. Dining, Travel, Groceries" />=0A      </div>=0A      <div class=3D"form-group">=0A        <label class=3D"form-label">Transfer Partners <span style=3D"opacity:0.5;font-weight:400">(auto-filled)</span></label>=0A        <input class=3D"form-input" id=3D"f-redeem" placeholder=3D"e.g. United, Hyatt, Southwest" />=0A      </div>=0A      <div class=3D"form-group">=0A        <label class=3D"form-label">Transfer Ratio</label>=0A        <input class=3D"form-input" id=3D"f-ratio" placeholder=3D"e.g. 1:1" />=0A      </div>=0A      <div class=3D"form-group">=0A        <label class=3D"form-label">Annual Benefits <span style=3D"opacity:0.5;font-weight:400">(auto-filled)</span></label>=0A        <input class=3D"form-input" id=3D"f-coupons" placeholder=3D"e.g. $300 travel credit, Priority Pass" />=0A      </div>=0A      <div class=3D"form-group">=0A        <label class=3D"form-label">Owner</label>=0A        <select class=3D"form-input" id=3D"f-owner">=0A          <option value=3D"Me">=00 Me</option>=0A          <option value=3D"Wife">=00 Wife</option>=0A          <option value=3D"Shared">=00 Shared</option>=0A        </select>=0A      </div>=0A=0A      <div class=3D"form-group">=0A        <label class=3D"form-label">Card Icon</label>=0A        <div class=3D"emoji-grid" id=3D"emojiGrid"></div>=0A      </div>=0A      <div class=3D"form-group">=0A        <label class=3D"form-label">Card Color</label>=0A        <div class=3D"color-grid" id=3D"colorGrid"></div>=0A      </div>=0A      <div class=3D"form-actions">=0A        <button class=3D"cancel-btn" onclick=3D"closeAddModal()">Cancel</button>=0A        <button class=3D"add-btn" onclick=3D"saveCard()">Save Card</button>=0A      </div>=0A    </div>=0A  </div>=0A</div>=0A=0A<script>=0A// =00=00=00 Constants =00=00=00=00=00=00=00=00=00=00=00=00=00=00=00=00=00=00=00=00=00=00=00=00=00=00=00=00=00=00=00=00=00=00=00=00=00=00=00=00=00=00=00=00=00=00=00=00=00=00=0Aconst EMOJIS =3D ['=00','=00','=00','=00','=00','=00','=00','=00','=00','=00','=00','=00','=00','=00','=00','=00'];=0Aconst COLORS =3D ['#FF6B6B','#FF9500','#FFCC02','#34C759','#00C7BE','#007AFF','#5856D6','#AF52DE','#FF2D55','#8E8E93'];=0Aconst TAG_COLORS =3D ['','green','orange','purple','red','teal','','green','orange','purple'];=0A=0Afunction saveCards() {=0A  localStorage.setItem('cpCards', JSON.stringify(cards));=0A}=0A=0A// =00=00 Safe data load with validation & auto-repair =00=00=00=00=00=00=00=00=00=00=00=00=00=00=00=00=00=00=0Afunction isValidCard(c) {=0A  return c && typeof c.id !=3D=3D 'undefined' &&=0A    typeof c.name =3D=3D=3D 'string' &&=0A    typeof c.bank =3D=3D=3D 'string' &&=0A    typeof c.points =3D=3D=3D 'number' &&=0A    Array.isArray(c.perks) &&=0A    Array.isArray(c.redeem) &&=0A    Array.isArray(c.coupons);=0A}=0A=0Afunction loadCards() {=0A  try {=0A    const raw =3D localStorage.getItem('cpCards');=0A    if (!raw) return null;=0A    const parsed =3D JSON.parse(raw);=0A    if (!Array.isArray(parsed)) return null;=0A    // Repair any partially-valid cards, drop totally broken ones=0A    const repaired =3D parsed.map(c =3D> {=0A      if (!c || typeof c !=3D=3D 'object') return null;=0A      return {=0A        id:      c.id      ?? Date.now(),=0A        name:    typeof c.name   =3D=3D=3D 'string' ? c.name   : 'Unknown Card',=0A        bank:    typeof c.bank   =3D=3D=3D 'string' ? c.bank   : 'Unknown Bank',=0A        icon:    typeof c.icon   =3D=3D=3D 'string' ? c.icon   : '=00',=0A        color:   typeof c.color  =3D=3D=3D 'string' ? c.color  : '#007AFF',=0A        points:  typeof c.points =3D=3D=3D 'number' ? c.points : 0,=0A        due:     typeof c.due    =3D=3D=3D 'string' ? c.due    : '',=0A        owner:   typeof c.owner  =3D=3D=3D 'string' ? c.owner  : 'Me',=0A        perks:   Array.isArray(c.perks)   ? c.perks   : [],=0A        redeem:  Array.isArray(c.redeem)  ? c.redeem.map(r =3D> ({=0A          name:  typeof r.name  =3D=3D=3D 'string' ? r.name  : '',=0A          ratio: typeof r.ratio =3D=3D=3D 'string' ? r.ratio : '1:1',=0A          est:   typeof r.est   =3D=3D=3D 'number' ? r.est   : 0,=0A        })) : [],=0A        coupons: Array.isArray(c.coupons) ? c.coupons.map(x =3D> ({=0A          text:   typeof x.text   =3D=3D=3D 'string'  ? x.text   : '',=0A          expiry: typeof x.expiry =3D=3D=3D 'string'  ? x.expiry : '',=0A          done:   typeof x.done   =3D=3D=3D 'boolean' ? x.done   : false,=0A        })) : [],=0A        history: Array.isArray(c.history) ? c.history : [],=0A      };=0A    }).filter(Boolean);=0A    return repaired.length > 0 ? repaired : null;=0A  } catch(e) {=0A    console.warn('cpCards parse error, resetting:', e);=0A    localStorage.removeItem('cpCards');=0A    return null;=0A  }=0A}=0A=0Aconst DEFAULT_CARDS =3D [=0A  {=0A    id: 1, name: 'Chase Sapphire Reserve', bank: 'Chase',=0A    icon: '=00', color: '#007AFF', points: 85000, due: '2025-08-15', owner: 'Me',=0A    perks: ['3x Dining', '3x Travel', '1.5x Everything', 'Priority Pass Lounge'],=0A    redeem: [=0A      { name: 'United MileagePlus', ratio: '1:1', est: 85000 },=0A      { name: 'World of Hyatt',     ratio: '1:1', est: 85000 },=0A      { name: 'Southwest Rapid Rewards', ratio: '1:1', est: 85000 },=0A      { name: 'Air Canada Aeroplan',     ratio: '1:1', est: 85000 },=0A    ],=0A    coupons: [=0A      { text: '$300 Annual Travel Credit', expiry: '2026-01-01', done: false },=0A      { text: 'Global Entry / TSA PreCheck Fee Credit', expiry: '2026-01-01', done: true },=0A      { text: 'DoorDash DashPass (complimentary)', expiry: '2025-12-31', done: false },=0A    ],=0A    history: [],=0A  },=0A  {=0A    id: 2, name: 'Amex Platinum', bank: 'American Express',=0A    icon: '=00', color: '#AF52DE', points: 120000, due: '2025-08-20', owner: 'Wife',=0A    perks: ['5x Flights booked directly', '5x Prepaid Hotels via Amex', 'Centurion Lounge Access', 'Fine Hotels & Resorts'],=0A    redeem: [=0A      { name: 'Delta SkyMiles',          ratio: '1:1', est: 120000 },=0A      { name: 'British Airways Avios',   ratio: '1:1', est: 120000 },=0A      { name: 'Air France/KLM Flying Blue', ratio: '1:1', est: 120000 },=0A      { name: 'Marriott Bonvoy',         ratio: '1:2', est: 240000 },=0A    ],=0A    coupons: [=0A      { text: '$200 Airline Fee Credit', expiry: '2025-12-31', done: false },=0A      { text: '$200 Fine Hotels Credit', expiry: '2025-12-31', done: false },=0A      { text: '$240 Digital Entertainment Credit', expiry: '2025-12-31', done: true },=0A      { text: 'Centurion Lounge Access (unlimited)', expiry: '2026-01-01', done: false },=0A      { text: '$189 CLEAR Plus Credit', expiry: '2025-12-31', done: false },=0A    ],=0A    history: [],=0A  },=0A  {=0A    id: 3, name: 'Chase Freedom Unlimited', bank: 'Chase',=0A    icon: '=00', color: '#34C759', points: 22000, due: '2025-08-05', owner: 'Me',=0A    perks: ['1.5x Everything', '3x Dining', '3x Drugstores', '5x Travel via Chase Portal'],=0A    redeem: [=0A      { name: 'Chase Ultimate Rewards (cash)', ratio: '1:1', est: 22000 },=0A    ],=0A    coupons: [=0A      { text: 'No Annual Fee', expiry: '', done: false },=0A    ],=0A    history: [],=0A  },=0A  {=0A    id: 4, name: 'Amex Gold', bank: 'American Express',=0A    icon: '=00', color: '#FF9500', points: 45000, due: '2025-08-28', owner: 'Wife',=0A    perks: ['4x Dining worldwide', '4x US Supermarkets (up to $25k/yr)', '3x Flights', '1x Everything else'],=0A    redeem: [=0A      { name: 'Delta SkyMiles',             ratio: '1:1', est: 45000 },=0A      { name: 'Air Canada Aeroplan',        ratio: '1:1', est: 45000 },=0A      { name: 'British Airways Avios',      ratio: '1:1', est: 45000 },=0A      { name: 'Marriott Bonvoy',            ratio: '1:2', est: 90000 },=0A    ],=0A    coupons: [=0A      { text: '$120 Dining Credit ($10/mo at select restaurants)', expiry: '2025-12-31', done: false },=0A      { text: '$120 Uber Cash ($10/mo)', expiry: '2025-12-31', done: false },=0A    ],=0A    history: [],=0A  },=0A];=0A=0A// Force-clear any legacy/corrupted data, then reload clean=0A(function() {=0A  try {=0A    const raw =3D localStorage.getItem('cpCards');=0A    if (raw) {=0A      const parsed =3D JSON.parse(raw);=0A      const isBad =3D !Array.isArray(parsed) ||=0A        parsed.some(c =3D> !c.name || !c.bank || !Array.isArray(c.redeem)) ||=0A        parsed.some(c =3D> /[\u4e00-\u9fff]/.test(c.name + c.bank)); // wipe Taiwan/Chinese data=0A      if (isBad) localStorage.removeItem('cpCards');=0A    }=0A  } catch(e) {=0A    localStorage.removeItem('cpCards');=0A  }=0A})();=0A=0Alet cards =3D loadCards() || DEFAULT_CARDS;=0Aif (!loadCards()) saveCards();=0A=0Alet currentTab =3D 'all';=0Alet currentNav =3D 'cards';=0Alet selectedEmoji =3D '=00';=0Alet selectedColor =3D COLORS[5];=0Alet searchQuery =3D '';=0A=0A// =00=00=00 Search =00=00=00=00=00=00=00=00=00=00=00=00=00=00=00=00=00=00=00=00=00=00=00=00=00=00=00=00=00=00=00=00=00=00=00=00=00=00=00=00=00=00=00=00=00=00=00=00=00=00=00=00=00=00=0Afunction handleSearch(val) {=0A  searchQuery =3D val.toLowerCase();=0A  renderAll();=0A}=0A=0A// =00=00=00 Nav =00=00=00=00=00=00=00=00=00=00=00=00=00=00=00=00=00=00=00=00=00=00=00=00=00=00=00=00=00=00=00=00=00=00=00=00=00=0