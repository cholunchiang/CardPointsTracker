<!DOCTYPE html>=0A<html lang=3D"zh-TW">=0A<head>=0A<meta charset=3D"UTF-8">=0A<meta name=3D"viewport" content=3D"width=3Ddevice-width, initial-scale=3D1.0, maximum-scale=3D1.0">=0A<title>=00 Card Points Tracker</title>=0A<style>=0A  :root { color-scheme: light dark; }=0A=0A  * { box-sizing: border-box; margin: 0; padding: 0; }=0A=0A  body {=0A    font-family: -apple-system, BlinkMacSystemFont, 'SF Pro Display', 'SF Pro Text', sans-serif;=0A    min-height: 100%;=0A    padding: 0;=0A    transition: background 0.3s, color 0.3s;=0A    -webkit-font-smoothing: antialiased;=0A  }=0A=0A  @media (prefers-color-scheme: light) {=0A    body { background: #f2f2f7; color: #1d1d1f; }=0A    .top-bar { background: rgba(255,255,255,0.85); border-bottom: 1px solid rgba(0,0,0,0.1); }=0A    .search-box { background: rgba(118,118,128,0.12); color: #1d1d1f; }=0A    .search-box::placeholder { color: #86868b; }=0A    .card-tile { background: #fff; border: 1px solid rgba(0,0,0,0.08); }=0A    .card-tile:hover { box-shadow: 0 6px 24px rgba(0,0,0,0.12); }=0A    .section-label { color: #86868b; }=0A    .tag { background: rgba(0,122,255,0.1); color: #007AFF; }=0A    .tag.green { background: rgba(52,199,89,0.12); color: #34C759; }=0A    .tag.orange { background: rgba(255,149,0,0.12); color: #FF9500; }=0A    .tag.purple { background: rgba(175,82,222,0.12); color: #AF52DE; }=0A    .tag.red { background: rgba(255,59,48,0.12); color: #FF3B30; }=0A    .tag.teal { background: rgba(90,200,250,0.18); color: #32ADE6; }=0A    .modal-bg { background: rgba(0,0,0,0.35); }=0A    .modal { background: #fff; }=0A    .modal-header { border-bottom: 1px solid rgba(0,0,0,0.08); }=0A    .detail-row { border-bottom: 1px solid rgba(0,0,0,0.06); }=0A    .detail-icon-bg { background: rgba(0,122,255,0.1); }=0A    .empty-state { color: #86868b; }=0A    .add-btn { background: #007AFF; }=0A    .add-btn:hover { background: #0071e3; }=0A    .form-input { background: rgba(118,118,128,0.1); border: 1px solid rgba(0,0,0,0.1); color: #1d1d1f; }=0A    .form-input:focus { border-color: #007AFF; background: #fff; }=0A    .cancel-btn { background: rgba(118,118,128,0.15); color: #1d1d1f; }=0A    .bank-chip { background: rgba(0,0,0,0.06); color: #3c3c43; }=0A    .coupon-item { background: rgba(255,149,0,0.08); border-left: 3px solid #FF9500; }=0A    .coupon-item.used { opacity: 0.45; }=0A    .nav-bar { background: rgba(255,255,255,0.9); border-top: 1px solid rgba(0,0,0,0.1); }=0A    .nav-btn.active { color: #007AFF; }=0A    .nav-btn { color: #86868b; }=0A    .fab { background: #007AFF; box-shadow: 0 4px 16px rgba(0,122,255,0.4); }=0A    .summary-card { background: linear-gradient(135deg, #007AFF, #5AC8FA); color: #fff; }=0A    .progress-bar-bg { background: rgba(0,0,0,0.08); }=0A    .redemption-item { background: rgba(0,0,0,0.03); border: 1px solid rgba(0,0,0,0.06); }=0A  }=0A=0A  @media (prefers-color-scheme: dark) {=0A    body { background: #1c1c1e; color: #f5f5f7; }=0A    .top-bar { background: rgba(28,28,30,0.92); border-bottom: 1px solid rgba(255,255,255,0.08); }=0A    .search-box { background: rgba(118,118,128,0.24); color: #f5f5f7; }=0A    .search-box::placeholder { color: #636366; }=0A    .card-tile { background: #2c2c2e; border: 1px solid rgba(255,255,255,0.08); }=0A    .card-tile:hover { box-shadow: 0 6px 24px rgba(0,0,0,0.4); }=0A    .section-label { color: #636366; }=0A    .tag { background: rgba(10,132,255,0.2); color: #0A84FF; }=0A    .tag.green { background: rgba(48,209,88,0.18); color: #30D158; }=0A    .tag.orange { background: rgba(255,159,10,0.18); color: #FF9F0A; }=0A    .tag.purple { background: rgba(191,90,242,0.18); color: #BF5AF2; }=0A    .tag.red { background: rgba(255,69,58,0.18); color: #FF453A; }=0A    .tag.teal { background: rgba(100,210,255,0.18); color: #64D2FF; }=0A    .modal-bg { background: rgba(0,0,0,0.6); }=0A    .modal { background: #2c2c2e; }=0A    .modal-header { border-bottom: 1px solid rgba(255,255,255,0.08); }=0A    .detail-row { border-bottom: 1px solid rgba(255,255,255,0.06); }=0A    .detail-icon-bg { background: rgba(10,132,255,0.2); }=0A    .empty-state { color: #636366; }=0A    .add-btn { background: #0A84FF; }=0A    .add-btn:hover { background: #007AFF; }=0A    .form-input { background: rgba(118,118,128,0.2); border: 1px solid rgba(255,255,255,0.1); color: #f5f5f7; }=0A    .form-input:focus { border-color: #0A84FF; background: rgba(10,132,255,0.08); }=0A    .cancel-btn { background: rgba(118,118,128,0.25); color: #f5f5f7; }=0A    .bank-chip { background: rgba(255,255,255,0.1); color: #ebebf5; }=0A    .coupon-item { background: rgba(255,159,10,0.1); border-left: 3px solid #FF9F0A; }=0A    .coupon-item.used { opacity: 0.35; }=0A    .nav-bar { background: rgba(28,28,30,0.95); border-top: 1px solid rgba(255,255,255,0.08); }=0A    .nav-btn.active { color: #0A84FF; }=0A    .nav-btn { color: #636366; }=0A    .fab { background: #0A84FF; box-shadow: 0 4px 20px rgba(10,132,255,0.45); }=0A    .summary-card { background: linear-gradient(135deg, #0A84FF, #30D158); color: #fff; }=0A    .progress-bar-bg { background: rgba(255,255,255,0.1); }=0A    .redemption-item { background: rgba(255,255,255,0.04); border: 1px solid rgba(255,255,255,0.08); }=0A  }=0A=0A  /* =00=00 Layout =00=00 */=0A  #app { max-width: 430px; margin: 0 auto; position: relative; }=0A=0A  .top-bar {=0A    position: sticky; top: 0; z-index: 100;=0A    padding: 16px 16px 12px;=0A    backdrop-filter: blur(20px); -webkit-backdrop-filter: blur(20px);=0A  }=0A  .top-bar h1 { font-size: 28px; font-weight: 700; letter-spacing: -0.5px; margin-bottom: 10px; }=0A  .top-bar h1 span { font-size: 26px; }=0A=0A  .search-wrap { position: relative; }=0A  .search-icon { position: absolute; left: 10px; top: 50%; transform: translateY(-50%); font-size: 15px; pointer-events: none; opacity: 0.5; }=0A  .search-box {=0A    width: 100%; padding: 8px 12px 8px 34px;=0A    border: none; border-radius: 12px;=0A    font-size: 15px; outline: none;=0A    transition: all 0.2s;=0A  }=0A=0A  .tab-row {=0A    display: flex; gap: 6px; padding: 10px 16px 0;=0A    overflow-x: auto; -webkit-overflow-scrolling: touch;=0A    scrollbar-width: none;=0A  }=0A  .tab-row::-webkit-scrollbar { display: none; }=0A  .tab-pill {=0A    flex-shrink: 0; padding: 5px 14px;=0A    border-radius: 20px; border: none; cursor: pointer;=0A    font-size: 13px; font-weight: 500;=0A    transition: all 0.2s;=0A  }=0A  @media (prefers-color-scheme: light) {=0A    .tab-pill { background: rgba(118,118,128,0.12); color: #3c3c43; }=0A    .tab-pill.active { background: #007AFF; color: #fff; }=0A  }=0A  @media (prefers-color-scheme: dark) {=0A    .tab-pill { background: rgba(118,118,128,0.25); color: #ebebf5; }=0A    .tab-pill.active { background: #0A84FF; color: #fff; }=0A  }=0A=0A  .content-area { padding: 12px 16px 100px; }=0A=0A  .section-label {=0A    font-size: 12px; font-weight: 600; letter-spacing: 0.5px;=0A    text-transform: uppercase; margin: 14px 0 8px;=0A  }=0A=0A  /* =00=00 Card Tile =00=00 */=0A  .card-tile {=0A    border-radius: 16px; padding: 16px;=0A    margin-bottom: 10px; cursor: pointer;=0A    transition: transform 0.15s, box-shadow 0.2s;=0A    backdrop-filter: blur(12px); -webkit-backdrop-filter: blur(12px);=0A  }=0A  .card-tile:active { transform: scale(0.98); }=0A=0A  .card-tile-header {=0A    display: flex; align-items: center; gap: 12px; margin-bottom: 12px;=0A  }=0A  .card-icon {=0A    width: 44px; height: 44px; border-radius: 12px;=0A    display: flex; align-items: center; justify-content: center;=0A    font-size: 22px; flex-shrink: 0;=0A  }=0A  .card-title-block { flex: 1; min-width: 0; }=0A  .card-name { font-size: 16px; font-weight: 600; }=0A  .card-bank { font-size: 12px; margin-top: 2px; }=0A  .bank-chip {=0A    display: inline-block; padding: 2px 8px;=0A    border-radius: 6px; font-size: 11px; font-weight: 500;=0A  }=0A  .points-badge {=0A    text-align: right; flex-shrink: 0;=0A  }=0A  .points-num { font-size: 20px; font-weight: 700; }=0A  .points-unit { font-size: 11px; opacity: 0.6; }=0A=0A  .tags-row { display: flex; flex-wrap: wrap; gap: 5px; margin-bottom: 10px; }=0A  .tag {=0A    padding: 3px 10px; border-radius: 8px;=0A    font-size: 12px; font-weight: 500;=0A  }=0A=0A  .progress-section { margin-top: 4px; }=0A  .progress-label {=0A    display: flex; justify-content: space-between;=0A    font-size: 11px; opacity: 0.65; margin-bottom: 4px;=0A  }=0A  .progress-bar-bg { border-radius: 4px; height: 5px; overflow: hidden; }=0A  .progress-bar-fill {=0A    height: 100%; border-radius: 4px;=0A    background: linear-gradient(90deg, #007AFF, #5AC8FA);=0A    transition: width 0.6s ease;=0A  }=0A=0A  /* =00=00 Summary Card =00=00 */=0A  .summary-card {=0A    border-radius: 20px; padding: 20px; margin-bottom: 16px;=0A    position: relative; overflow: hidden;=0A  }=0A  .summary-card::before {=0A    content: ''; position: absolute;=0A    top: -20px; right: -20px; width: 100px; height: 100px;=0A    background: rgba(255,255,255,0.1); border-radius: 50%;=0A  }=0A  .summary-title { font-size: 13px; font-weight: 500; opacity: 0.85; }=0A  .summary-num { font-size: 36px; font-weight: 800; letter-spacing: -1px; margin: 4px 0; }=0A  .summary-sub { font-size: 12px; opacity: 0.75; }=0A=0A  /* =00=00 FAB =00=00 */=0A  .fab {=0A    position: fixed; bottom: 90px; right: calc(50% - 215px + 16px);=0A    width: 52px; height: 52px; border-radius: 50%;=0A    border: none; cursor: pointer; font-size: 26px;=0A    display: flex; align-items: center; justify-content: center;=0A    color: #fff; z-index: 200;=0A    transition: transform 0.2s;=0A  }=0A  .fab:active { transform: scale(0.92); }=0A=0A  /* =00=00 Nav Bar =00=00 */=0A  .nav-bar {=0A    position: fixed; bottom: 0; left: 50%; transform: translateX(-50%);=0A    width: 100%; max-width: 430px;=0A    display: flex; padding: 8px 0 20px;=0A    backdrop-filter: blur(20px); -webkit-backdrop-filter: blur(20px);=0A    z-index: 150;=0A  }=0A  .nav-btn {=0A    flex: 1; display: flex; flex-direction: column;=0A    align-items: center; gap: 2px;=0A    background: none; border: none; cursor: pointer;=0A    font-size: 11px; font-weight: 500;=0A    transition: color 0.2s;=0A  }=0A  .nav-btn .nav-icon { font-size: 22px; }=0A=0A  /* =00=00 Modal =00=00 */=0A  .modal-bg {=0A    position: fixed; inset: 0; z-index: 300;=0A    display: flex; align-items: flex-end;=0A    backdrop-filter: blur(4px); -webkit-backdrop-filter: blur(4px);=0A  }=0A  .modal-bg.hidden { display: none; }=0A  .modal {=0A    width: 100%; max-width: 430px; margin: 0 auto;=0A    border-radius: 24px 24px 0 0;=0A    max-height: 88vh; overflow-y: auto;=0A    animation: slideUp 0.3s cubic-bezier(0.34,1.56,0.64,1);=0A  }=0A  @keyframes slideUp {=0A    from { transform: translateY(100%); }=0A    to { transform: translateY(0); }=0A  }=0A  .modal-handle {=0A    width: 36px; height: 4px; border-radius: 2px;=0A    background: rgba(128,128,128,0.3); margin: 10px auto 4px;=0A  }=0A  .modal-header {=0A    display: flex; align-items: center; justify-content: space-between;=0A    padding: 12px 20px 14px;=0A  }=0A  .modal-title { font-size: 20px; font-weight: 700; }=0A  .close-btn {=0A    width: 30px; height: 30px; border-radius: 50%; border: none;=0A    cursor: pointer; font-size: 16px; display: flex;=0A    align-items: center; justify-content: center;=0A    background: rgba(128,128,128,0.2); color: inherit;=0A  }=0A  .modal-body { padding: 0 20px 24px; }=0A=0A  .detail-row {=0A    display: flex; align-items: flex-start; gap: 12px;=0A    padding: 14px 0;=0A  }=0A  .detail-icon-bg {=0A    width: 36px; height: 36px; border-radius: 10px;=0A    display: flex; align-items: center; justify-content: center;=0A    font-size: 18px; flex-shrink: 0;=0A  }=0A  .detail-content { flex: 1; }=0A  .detail-label { font-size: 12px; opacity: 0.6; margin-bottom: 3px; }=0A  .detail-value { font-size: 14px; font-weight: 500; }=0A=0A  .coupon-item {=0A    padding: 10px 12px; border-radius: 10px; margin-bottom: 6px;=0A    display: flex; align-items: center; gap: 10px;=0A    transition: opacity 0.2s;=0A  }=0A  .coupon-check {=0A    width: 20px; height: 20px; border-radius: 50%; border: none;=0A    cursor: pointer; font-size: 13px; display: flex;=0A    align-items: center; justify-content: center;=0A    flex-shrink: 0; transition: all 0.2s;=0A  }=0A  @media (prefers-color-scheme: light) {=0A    .coupon-check { background: rgba(255,149,0,0.2); color: #FF9500; }=0A    .coupon-check.done { background: #34C759; color: #fff; }=0A  }=0A  @media (prefers-color-scheme: dark) {=0A    .coupon-check { background: rgba(255,159,10,0.2); color: #FF9F0A; }=0A    .coupon-check.done { background: #30D158; color: #fff; }=0A  }=0A  .coupon-text { flex: 1; font-size: 13px; font-weight: 500; }=0A  .coupon-expiry { font-size: 11px; opacity: 0.55; }=0A=0A  .redemption-item {=0A    border-radius: 12px; padding: 12px; margin-bottom: 8px;=0A    display: flex; justify-content: space-between; align-items: center;=0A  }=0A  .redemption-name { font-size: 14px; font-weight: 600; }=0A  .redemption-ratio { font-size: 13px; opacity: 0.7; }=0A  .redemption-value { font-size: 15px; font-weight: 700; }=0A=0A  /* =00=00 Add Card Form =00=00 */=0A  .form-group { margin-bottom: 14px; }=0A  .form-label { font-size: 13px; font-weight: 600; margin-bottom: 6px; opacity: 0.8; display: block; }=0A  .form-input {=0A    width: 100%; padding: 10px 14px;=0A    border-radius: 12px; font-size: 14px;=0A    outline: none; transition: all 0.2s;=0A  }=0A  .form-row { display: grid; grid-template-columns: 1fr 1fr; gap: 10px; }=0A  .form-actions { display: flex; gap: 10px; margin-top: 20px; }=0A  .add-btn, .cancel-btn {=0A    flex: 1; padding: 13px; border-radius: 14px; border: none;=0A    font-size: 15px; font-weight: 600; cursor: pointer;=0A    transition: all 0.2s;=0A  }=0A  .add-btn { color: #fff; }=0A=0A  .emoji-grid {=0A    display: grid; grid-template-columns: repeat(6, 1fr); gap: 6px; margin-top: 6px;=0A  }=0A  .emoji-btn {=0A    aspect-ratio: 1; border-radius: 10px; border: none;=0A    font-size: 20px; cursor: pointer; display: flex;=0A    align-items: center; justify-content: center;=0A    transition: all 0.15s;=0A  }=0A  @media (prefers-color-scheme: light) {=0A    .emoji-btn { background: rgba(118,118,128,0.1); }=0A    .emoji-btn.selected { background: rgba(0,122,255,0.2); outline: 2px solid #007AFF; }=0A  }=0A  @media (prefers-color-scheme: dark) {=0A    .emoji-btn { background: rgba(118,118,128,0.2); }=0A    .emoji-btn.selected { background: rgba(10,132,255,0.25); outline: 2px solid #0A84FF; }=0A  }=0A=0A  .color-grid { display: flex; gap: 8px; flex-wrap: wrap; margin-top: 6px; }=0A  .color-btn {=0A    width: 32px; height: 32px; border-radius: 50%; border: 3px solid transparent;=0A    cursor: pointer; transition: all 0.15s;=0A  }=0A  .color-btn.selected { border-color: #fff; transform: scale(1.15); box-shadow: 0 0 0 2px #007AFF; }=0A=0A  .empty-state {=0A    text-align: center; padding: 60px 20px;=0A    font-size: 15px; line-height: 1.6;=0A  }=0A  .empty-state .big-emoji { font-size: 56px; display: block; margin-bottom: 12px; }=0A  .empty-state strong { font-size: 18px; display: block; margin-bottom: 6px; }=0A=0A  .view { display: none; }=0A  .view.active { display: block; }=0A</style>=0A</head>=0A<body>=0A<div id=3D"app">=0A  <!-- Top Bar -->=0A  <div class=3D"top-bar">=0A    <h1><span>=00</span> =00=00=00=00</h1>=0A    <div class=3D"search-wrap">=0A      <span class=3D"search-icon">=00</span>=0A      <input class=3D"search-box" id=3D"searchBox" type=3D"text" placeholder=3D"=00=00=00=00=00=00=00=00=00=00=00=00=00" oninput=3D"handleSearch(this.value)">=0A    </div>=0A  </div>=0A=0A  <!-- Tabs -->=0A  <div class=3D"tab-row" id=3D"tabRow"></div>=0A=0A  <!-- Content -->=0A  <div class=3D"content-area" id=3D"contentArea"></div>=0A=0A  <!-- FAB -->=0A  <button class=3D"fab" onclick=3D"openAddModal()" title=3D"=00=00=00=00=00">=00</button>=0A=0A  <!-- Nav Bar -->=0A  <div class=3D"nav-bar">=0A    <button class=3D"nav-bt