  const blob     =3D new Blob([json], { type: 'application/json' });
  const url      =3D URL.createObjectURL(blob);
  const date     =3D new Date().toISOString().slice(0,10);
  const filename =3D `CardPoints_backup_${date}.json`;
  // On iOS Safari this triggers the Share Sheet
  const a  =3D document.createElement('a');
  a.href   =3D url;
  a.download =3D filename;
  a.click();
  URL.revokeObjectURL(url);
}

function importBackup(event) {
  const file =3D event.target.files[0];
  if (!file) return;
  const reader =3D new FileReader();
  reader.onload =3D function(e) {
    try {
      const data   =3D JSON.parse(e.target.result);
      const parsed =3D data.cards || (Array.isArray(data) ? data : null);
      if (!parsed || !Array.isArray(parsed) || !parsed.length) {
        alert('Invalid backup file =00 no cards found.'); return;
      }
      if (!confirm(`Import ${parsed.length} cards? This will replace your c=
urrent data.`)) return;
      cards =3D parsed.map(c =3D> ({
        id:      c.id      ?? Date.now(),
        name:    c.name    ?? 'Unknown',
        bank:    c.bank    ?? 'Unknown',
        icon:    c.icon    ?? '=00',
        color:   c.color   ?? '#007AFF',
        points:  typeof c.points =3D=3D=3D 'number' ? c.points : 0,
        due:     c.due     ?? '',
        owner:   c.owner   ?? 'Me',
        perks:   Array.isArray(c.perks)   ? c.perks   : [],
        redeem:  Array.isArray(c.redeem)  ? c.redeem  : [],
        coupons: Array.isArray(c.coupons) ? c.coupons : [],
        history: Array.isArray(c.history) ? c.history : [],
      }));
      saveCards();
      renderAll();
      alert(`=00 Imported ${cards.length} cards successfully!`);
    } catch(err) {
      alert('Could not read file =00 make sure it\'s a valid CardPoints bac=
kup JSON.');
    }
  };
  reader.readAsText(file);
  event.target.value =3D ''; // reset so same file can be re-imported
}

// =00=00 Log Points =00=00=00=00=00=00=00=00=00=00=00=00=00=00=00=00=00=00=
=00=00=00=00=00=00=00=00=00=00=00=00=00=00=00=00=00=00=00=00=00=00=00=00=00=
=00=00=00=00=00=00=00=00
let logCardId  =3D null;
let logType    =3D 'earned';

function openLogModal(id) {
  logCardId =3D id;
  logType   =3D 'earned';
  setLogType('earned');
  document.getElementById('log-amount').value =3D '';
  document.getElementById('log-note').value   =3D '';
  document.getElementById('log-date').value   =3D new Date().toISOString().=
slice(0,10);
  document.getElementById('logModal').classList.remove('hidden');
}
function closeLogModal() { document.getElementById('logModal').classList.ad=
d('hidden'); }

function setLogType(t) {
  logType =3D t;
  const eBtn =3D document.getElementById('log-type-earned');
  const sBtn =3D document.getElementById('log-type-spent');
  eBtn.style.borderColor  =3D t=3D=3D=3D'earned' ? '#34C759' : 'rgba(128,12=
8,128,0.3)';
  eBtn.style.background   =3D t=3D=3D=3D'earned' ? 'rgba(52,199,89,0.12)' :=
 'transparent';
  eBtn.style.color        =3D t=3D=3D=3D'earned' ? '#34C759' : 'inherit';
  sBtn.style.borderColor  =3D t=3D=3D=3D'spent'  ? '#FF3B30' : 'rgba(128,12=
8,128,0.3)';
  sBtn.style.background   =3D t=3D=3D=3D'spent'  ? 'rgba(255,59,48,0.08)' :=
 'transparent';
  sBtn.style.color        =3D t=3D=3D=3D'spent'  ? '#FF3B30' : 'inherit';
}

function saveLog() {
  const amt  =3D parseInt(document.getElementById('log-amount').value);
  const date =3D document.getElementById('log-date').value;
  const note =3D document.getElementById('log-note').value.trim();
  if (!amt || amt <=3D 0) { alert('Please enter a valid point amount'); ret=
urn; }
  if (!date)            { alert('Please select a date'); return; }
  const c =3D cards.find(x =3D> x.id =3D=3D=3D logCardId);
  if (!c) return;
  if (!c.history) c.history =3D [];
  c.history.unshift({ type: logType, amount: amt, date, note });
  c.points =3D logType =3D=3D=3D 'earned' ? c.points + amt : Math.max(0, c.=
points - amt);
  // Update redeem estimates based on new balance
  const ratio =3D c.redeem[0]?.ratio || '1:1';
  const [a, b] =3D ratio.split(':').map(Number);
  c.redeem =3D c.redeem.map(r =3D> ({ ...r, est: Math.floor(c.points / (a||=
1) * (b||1)) }));
  saveCards();
  closeLogModal();
  openDetail(logCardId);
  renderAll();
}

