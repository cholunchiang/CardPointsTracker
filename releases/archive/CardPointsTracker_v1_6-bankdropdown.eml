function autofillCard(val) {
  const key =3D val.toLowerCase().trim();
  const match =3D Object.keys(CARD_DB).find(k =3D> key.includes(k)||k.inclu=
des(key));
  if (!match) return;
  const d =3D CARD_DB[match];
  document.getElementById('f-bank').value    =3D d.bank    || '';
  document.getElementById('f-perks').value   =3D d.perks   ? d.perks.join('=
, ')   : '';
  document.getElementById('f-redeem').value  =3D d.redeem  ? d.redeem.join(=
', ')  : '';
  document.getElementById('f-ratio').value   =3D d.ratio   || '1:1';
  document.getElementById('f-coupons').value =3D d.coupons ? d.coupons.join=
(', ') : '';
