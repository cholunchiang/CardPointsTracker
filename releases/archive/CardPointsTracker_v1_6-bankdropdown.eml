function saveCard() {
  const name  =3D document.getElementById('f-name').value.trim();
  const bank  =3D document.getElementById('f-bank').value.trim();
  if (!name||!bank) { alert('Please enter card name and bank'); return; }
  const pts   =3D parseInt(document.getElementById('f-points').value)||0;
  const due   =3D document.getElementById('f-due').value;
  const owner =3D document.getElementById('f-owner')?.value||'Me';
  const perks =3D document.getElementById('f-perks').value.split(',').map(s=
=3D>s.trim()).filter(Boolean);
  const rNames=3D document.getElementById('f-redeem').value.split(',').map(=
s=3D>s.trim()).filter(Boolean);
  const ratio =3D document.getElementById('f-ratio').value.trim()||'1:1';
  const [a,b] =3D ratio.split(':').map(Number);
  const est   =3D b&&a?Math.floor(pts/a*b):pts;
  const cRaw  =3D document.getElementById('f-coupons').value.split(',').map=
(s=3D>s.trim()).filter(Boolean);
  cards.push({
    id:Date.now(), name, bank, icon:selEmoji, color:selColor,
    points:pts, due, owner,
    perks: perks.length?perks:['General spending'],
    redeem: rNames.map(r=3D>({name:r,ratio,est})),
    coupons: cRaw.map(t=3D>({text:t,expiry:'',done:false})),
    history:[],
  });
  saveCards(); closeAddModal(); renderAll();
}

