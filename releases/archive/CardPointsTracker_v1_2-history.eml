A    .owner-shared { background: rgba(48,209,88,0.2); color: #30D158; }=0A  }=0A=0A  #app { max-width: 430px; margin: 0 auto; }=0A  .top-bar { position: sticky; top: 0; z-index: 100; padding: 16px 16px 12px; backdrop-filter: blur(20px); -webkit-backdrop-filter: blur(20px); }=0A  .top-bar h1 { font-size: 28px; font-weight: 700; letter-spacing: -0.5px; margin-bottom: 10px; }=0A  .search-wrap { position: relative; }=0A  .search-icon { position: absolute; left: 10px; top: 50%; transform: translateY(-50%); font-size: 15px; pointer-events: none; opacity: 0.5; }=0A  .search-box { width: 100%; padding: 8px 12px 8px 34px; border: none; border-radius: 12px; font-size: 15px; outline: none; }=0A  .tab-row { display: flex; gap: 6px; padding: 10px 16px 0; overflow-x: auto; -webkit-overflow-scrolling: touch; scrollbar-width: none; }=0A  .tab-row::-webkit-scrollbar { display: none; }=0A  .tab-pill { flex-shrink: 0; padding: 5px 14px; border-radius: 20px; border: none; cursor: pointer; font-size: 13px; font-weight: 500; transition: all 0.2s; }=0A  .content-area { padding: 12px 16px 100px; }=0A  .section-label { font-size: 12px; font-weight: 600; letter-spacing: 0.5px; text-transform: uppercase; margin: 14px 0 8px; }=0A  .card-tile { border-radius: 16px; padding: 16px; margin-bottom: 10px; cursor: pointer; transition: transform 0.15s; }=0A  .card-tile:active { transform: scale(0.98); }=0A  .card-tile-header { display: flex; align-items: center; gap: 12px; margin-bottom: 12px; }=0A  .card-icon { width: 44px; height: 44px; border-radius: 12px; display: flex; align-items: center; justify-content: center; font-size: 22px; flex-shrink: 0; }=0A  .card-title-block { flex: 1; min-width: 0; }=0A  .card-name { font-size: 16px; font-weight: 600; }=0A  .card-bank { font-size: 12px; margin-top: 2px; }=0A  .bank-chip { display: inline-block; padding: 2px 8px; border-radius: 6px; font-size: 11px; font-weight: 500; }=0A  .owner-chip { display: inline-block; padding: 1px 7px; border-radius: 6px; font