:grid;grid-template-columns:1fr 1fr;gap:8px">=0A          <button id=3D"log-type-earned" onclick=3D"setLogType('earned')" style=3D"padding:10px;border-radius:12px;border:2px solid #34C759;background:rgba(52,199,89,0.12);color:#34C759;font-size:14px;font-weight:600;cursor:pointer">+ Earned</button>=0A          <button id=3D"log-type-spent"  onclick=3D"setLogType('spent')"  style=3D"padding:10px;border-radius:12px;border:2px solid rgba(128,128,128,0.3);background:transparent;color:inherit;font-size:14px;font-weight:600;cursor:pointer">=00 Spent / Redeemed</button>=0A        </div>=0A      </div>=0A      <div class=3D"form-row">=0A        <div class=3D"form-group">=0A          <label class=3D"form-label">Points</label>=0A          <input class=3D"form-input" id=3D"log-amount" type=3D"number" placeholder=3D"0" min=3D"0" />=0A        </div>=0A        <div class=3D"form-group">=0A          <label class=3D"form-label">Date</label>=0A          <input class=3D"form-input" id=3D"log-date" type=3D"date" />=0A        </div>=0A      </div>=0A      <div class=3D"form-group">=0A        <label class=3D"form-label">Note <span style=3D"opacity:0.5;font-weight:400">(optional)</span></label>=0A        <input class=3D"form-input" id=3D"log-note" placeholder=3D"e.g. Monthly spend, Transferred to United" />=0A      </div>=0A      <div class=3D"form-actions">=0A        <button class=3D"cancel-btn" onclick=3D"closeLogModal()">Cancel</button>=0A        <button class=3D"add-btn" onclick=3D"saveLog()">Save Entry</button>=0A      </div>=0A    </div>=0A  </div>=0A</div>=0A=0A<script>=0A// =00=00 Constants =00=00=00=00=00=00=00=00=00=00=00=00=00=00=00=00=00=00=00=00=00=00=00=00=00=00=00=00=00=00=00=00=00=00=00=00=00=00=00=00=00=00=00=00=00=00=00=00=00=00=00=00=0Aconst EMOJIS =3D ['=00','=00','=00','=00','=00','=00','=00','=00','=00','=00','=00','=00','=00','=00','=00','=00'];=0Aconst COLORS  =3D ['#FF6B6B','#FF9500','#FFCC02','#34C759','#00C7BE','#007AFF','#5856D6','#AF52DE','#FF2D55','#8E8E93'];=0Aconst TC      =3D ['','green','orange','purple','red','teal','','green','orange','purple'];=0A=0A// =00=00 Persistence =00=00=00=00=00=00=00=00=00=00=00=00=00=00=00=00=00=00=00=00=00=00=00=00=00=00=00=00=00=00=00=00=00=00=00=00=00=00=00=00=00=00=00=00=00=00=00=00=00=00=0Afunction saveCards() { localStorage.setItem('cpCards', JSON.stringify(cards)); }=0A=0Afunction loadCards() {=0A  try {=0A    const raw =3D localStorage.getItem('cpCards');=0A    if (!raw) return null;=0A    const parsed =3D JSON.parse(raw);=0A    if (!Array.isArray(parsed) || !parsed.length) return null;=0A    // wipe if any card looks like old Taiwan data or is malformed=0A    if (parsed.some(c =3D> !c.name || !c.bank || !Array.isArray(c.redeem) || /[\u4e00-\u9fff]/.test(c.name + c.bank))) {=0A      localStorage.removeItem('cpCards');=0A      return null;=0A    }=0A    return parsed.map(c =3D> ({=0A      id:      c.id      ?? Date.now(),=0A      name:    c.name    ?? 'Unknown',=0A      bank:    c.bank    ?? 'Unknown',=0A      icon:    c.icon    ?? '=00',=0A      color:   c.color   ?? '#007AFF',=0A      points:  typeof c.points =3D=3D=3D 'number' ? c.points : 0,=0A      due:     c.due     ?? '',=0A      owner:   c.owner   ?? 'Me',=0A      perks:   Array.isArray(c.perks)   ? c.perks   : [],=0A      redeem:  Array.isArray(c.redeem)  ? c.redeem  : [],=0A      coupons: Array.isArray(c.coupons) ? c.coupons : [],=0A      history: Array.isArray(c.history) ? c.history : [],=0A    }));=0A  } catch(e) { localStorage.removeItem('cpCards'); return null; }=0A}=0A=0Aconst DEFAULTS =3D [=0A  { id:1, name:'Chase Sapphire Reserve', bank:'Chase', icon:'=00', color:'#007AFF', points:85000, due:'2025-09-15', owner:'Me',=0A    perks:['3x Dining','3x Travel','1.5x Everything','Priority Pass Lounge'],=0A    redeem:[{name:'United MileagePlus',ratio:'1:1',est:85000},{name:'World of Hyatt',ratio:'1:1',est:85000},{name:'Southwest Rapid Rewards',ratio:'1:1',est:85000},{name:'Air Canada Aeroplan',ratio:'1:1',est:85000}],=0A 