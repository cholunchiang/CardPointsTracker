120 Uber Cash ($10/mo)',expiry:'2025-12-31',done:false}],=0A    history:[] },=0A];=0A=0Alet cards =3D loadCards() || DEFAULTS;=0Aif (!loadCards()) saveCards();=0A=0Alet currentTab  =3D 'all';=0Alet currentNav  =3D 'cards';=0Alet selEmoji    =3D '=00';=0Alet selColor    =3D '#007AFF';=0Alet searchQuery =3D '';=0A=0A// =00=00 Nav & Tabs =00=00=00=00=00=00=00=00=00=00=00=00=00=00=00=00=00=00=00=00=00=00=00=00=00=00=00=00=00=00=00=00=00=00=00=00=00=00=00=00=00=00=00=00=00=00=00=00=00=00=00=0Afunction switchNav(n) {=0A  currentNav =3D n;=0A  document.querySelectorAll('.nav-btn').forEach(b =3D> b.classList.remove('active'));=0A  document.getElementById('nav-' + n).classList.add('active');=0A  renderAll();=0A}=0A=0Afunction buildTabs() {=0A  const opts   =3D ['all','Me','Wife','Shared', ...new Set(cards.map(c =3D> c.bank))];=0A  const labels =3D { all:'All Cards', Me:'=00 Mine', Wife:'=00 Wife', Shared:'=00 Shared' };=0A  document.getElementById('tabRow').innerHTML =3D opts.map(o =3D>=0A    `<button class=3D"tab-pill ${o=3D=3D=3DcurrentTab?'active':''}" onclick=3D"setTab('${o}')">${labels[o]||o}</button>`=0A  ).join('');=0A}=0A=0Afunction setTab(t) { currentTab =3D t; renderAll(); }=0A=0Afunction handleSearch(v) { searchQuery =3D v.toLowerCase(); renderAll(); }=0A=0Afunction filtered() {=0A  let list =3D cards;=0A  if (['Me','Wife','Shared'].includes(currentTab)) list =3D cards.filter(c =3D> (c.owner||'Me') =3D=3D=3D currentTab);=0A  else if (currentTab !=3D=3D 'all') list =3D cards.filter(c =3D> c.bank =3D=3D=3D currentTab);=0A  if (searchQuery) list =3D list.filter(c =3D>=0A    c.name.toLowerCase().includes(searchQuery) ||=0A    c.bank.toLowerCase().includes(searchQuery) ||=0A    c.perks.some(p =3D> p.toLowerCase().includes(searchQuery)) ||=0A    c.redeem.some(r =3D> r.name.toLowerCase().includes(searchQuery)) ||=0A    (c.coupons||[]).some(x =3D> x.text.toLowerCase().includes(searchQuery))=0A  );=0A  return list;=0A}=0A=0A// =00=00 Render =00=00=00=00=00=00=00=00=00=00=00=00=00=00=00=00=00=00=00=00=00=00=00=00=00=00=00=00=00=00=00=00=00=00=00=00=00=00=00=00=00=00=00=00=00=00=00=00=00=00=00=00=00=00=00=0Afunction renderAll() {=0A  buildTabs();=0A  const area =3D document.getElementById('contentArea');=0A  const list =3D filtered();=0A  if (currentNav=3D=3D=3D'cards')   renderCards(area, list);=0A  else if (currentNav=3D=3D=3D'miles')   renderMiles(area, list);=0A  else if (currentNav=3D=3D=3D'coupons') renderCoupons(area, list);=0A  else renderSummary(area);=0A}=0A=0Afunction tc(i) { return TC[i % TC.length]; }=0A=0Afunction renderCards(area, list) {=0A  if (!list.length) { area.innerHTML =3D `<div class=3D"empty-state"><span class=3D"big-emoji">=00</span><strong>No cards yet</strong>Tap + to add your first card</div>`; return; }=0A  area.innerHTML =3D list.map(c =3D> {=0A    const due      =3D c.due ? new Date(c.due).toLocaleDateString('en-US',{month:'short',day:'numeric'}) : '';=0A    const daysLeft =3D c.due ? Math.ceil((new Date(c.due)-new Date())/86400000) : 99;=0A    const prog     =3D Math.max(0, Math.min(100, (1-daysLeft/30)*100));=0A    const owner    =3D (c.owner||'Me').toLowerCase();=0A    return `<div class=3D"card-tile" onclick=3D"openDetail(${c.id})">=0A      <div class=3D"card-tile-header">=0A        <div class=3D"card-icon" style=3D"background:${c.color}22">${c.icon}</div>=0A        <div class=3D"card-title-block">=0A          <div class=3D"card-name">${c.name}</div>=0A          <div class=3D"card-bank"><span class=3D"bank-chip">${c.bank}</span> <span class=3D"owner-chip owner-${owner}">${c.owner||'Me'}</span></div>=0A        </div>=0A        <div class=3D"points-badge"><div class=3D"points-num">${c.points.toLocaleString()}</div><div class=3D"points-unit">pts</div></div>=0A      </div>=0A      <div class=3D"tags-row">${c.perks.slice(0,4).map((p,i)=3D>`<span class=3D"tag ${tc(i)}">${p}</span>`).join('')}</div>=0A      ${c.due ? `<div class=3D"progress-section">=0A        <div class=3D"progress-label"><span>Statement $